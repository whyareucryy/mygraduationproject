@using Microsoft.AspNetCore.Identity
@using ComputerRepairService.Models.Entities
@inject SignInManager<ApplicationUser> SignInManager

@{
    ViewData["Title"] = "Главная";
}

<!-- Герой-секция -->
<section class="hero-section bg-gradient-primary text-white py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h1 class="display-4 fw-bold mb-3">
                    <i class="fas fa-tools me-2"></i> Компьютерный сервисный центр
                </h1>
                <p class="lead mb-4">
                    Профессиональный ремонт и обслуживание компьютерной техники.
                    Быстро, качественно, с гарантией!
                </p>

                @if (!SignInManager.IsSignedIn(User))
                {
                    <div class="d-flex gap-3">
                        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-light btn-lg px-4">
                            <i class="fas fa-user-plus me-2"></i> Зарегистрироваться
                        </a>
                        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-light btn-lg px-4">
                            <i class="fas fa-sign-in-alt me-2"></i> Войти
                        </a>
                    </div>
                }
                else
                {
                    <div class="d-flex gap-3">
                        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-light btn-lg px-4">
                            <i class="fas fa-tachometer-alt me-2"></i> Панель управления
                        </a>
                        <a asp-controller="Profile" asp-action="Index" class="btn btn-outline-light btn-lg px-4">
                            <i class="fas fa-user me-2"></i> Личный кабинет
                        </a>
                    </div>
                }
            </div>
            <div class="col-lg-6 text-center">
                <img src="https://cdn-icons-png.flaticon.com/512/3067/3067256.png"
                     alt="Компьютерный сервис"
                     class="img-fluid"
                     style="max-height: 300px;">
            </div>
        </div>
    </div>
</section>

<!-- Статистика -->
@if (SignInManager.IsSignedIn(User))
{
    <section class="stats-section py-4 bg-light">
        <div class="container">
            <div class="row">
                <div class="col-md-3 col-6 mb-3">
                    <div class="text-center">
                        <div class="stat-number text-primary fw-bold fs-3">
                            <i class="fas fa-clock me-2"></i> 24/7
                        </div>
                        <div class="stat-label text-muted">Поддержка</div>
                    </div>
                </div>
                <div class="col-md-3 col-6 mb-3">
                    <div class="text-center">
                        <div class="stat-number text-success fw-bold fs-3">
                            <i class="fas fa-shield-alt me-2"></i> 100%
                        </div>
                        <div class="stat-label text-muted">Гарантия</div>
                    </div>
                </div>
                <div class="col-md-3 col-6 mb-3">
                    <div class="text-center">
                        <div class="stat-number text-warning fw-bold fs-3">
                            <i class="fas fa-users me-2"></i> 50+
                        </div>
                        <div class="stat-label text-muted">Клиентов в день</div>
                    </div>
                </div>
                <div class="col-md-3 col-6 mb-3">
                    <div class="text-center">
                        <div class="stat-number text-info fw-bold fs-3">
                            <i class="fas fa-check-circle me-2"></i> 95%
                        </div>
                        <div class="stat-label text-muted">Успешных ремонтов</div>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

<!-- Быстрый доступ для авторизованных пользователей -->
@if (SignInManager.IsSignedIn(User))
{
    <section class="quick-access py-5">
        <div class="container">
            <h2 class="text-center mb-4">
                <i class="fas fa-bolt text-warning me-2"></i> Быстрый доступ
            </h2>

            <div class="row">
                <!-- Для всех авторизованных -->
                <div class="col-md-4 mb-4">
                    <div class="card border-primary h-100 shadow-sm">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="fas fa-user me-2"></i> Личный кабинет</h5>
                        </div>
                        <div class="card-body">
                            <p class="card-text">Управление профилем, заказами и настройками</p>
                            <div class="d-grid">
                                <a asp-controller="Profile" asp-action="Index" class="btn btn-outline-primary">
                                    <i class="fas fa-external-link-alt me-1"></i> Перейти
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Для клиентов -->
                @if (User.IsInRole("Client"))
                {
                    <div class="col-md-4 mb-4">
                        <div class="card border-success h-100 shadow-sm">
                            <div class="card-header bg-success text-white">
                                <h5 class="mb-0"><i class="fas fa-plus-circle me-2"></i> Новый заказ</h5>
                            </div>
                            <div class="card-body">
                                <p class="card-text">Создать заявку на ремонт вашего устройства</p>
                                <div class="d-grid">
                                    <a asp-controller="ServiceOrders" asp-action="Create" class="btn btn-outline-success">
                                        <i class="fas fa-plus me-1"></i> Создать заказ
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <!-- Для сотрудников и админов -->
                @if (User.IsInRole("Employee") || User.IsInRole("Admin"))
                {
                    <div class="col-md-4 mb-4">
                        <div class="card border-info h-100 shadow-sm">
                            <div class="card-header bg-info text-white">
                                <h5 class="mb-0"><i class="fas fa-tasks me-2"></i> Активные задачи</h5>
                            </div>
                            <div class="card-body">
                                <p class="card-text">Просмотр и управление текущими задачами</p>
                                <div class="d-grid">
                                    @if (User.IsInRole("Employee"))
                                    {
                                        <a asp-controller="ServiceOrders" asp-action="MyAssignedOrders" class="btn btn-outline-info">
                                            <i class="fas fa-list me-1"></i> Мои задачи
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-controller="ServiceOrders" asp-action="Index" class="btn btn-outline-info">
                                            <i class="fas fa-list me-1"></i> Все заказы
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <!-- Только для админов -->
                @if (User.IsInRole("Admin"))
                {
                    <div class="col-md-4 mb-4">
                        <div class="card border-warning h-100 shadow-sm">
                            <div class="card-header bg-warning text-white">
                                <h5 class="mb-0"><i class="fas fa-chart-bar me-2"></i> Отчеты</h5>
                            </div>
                            <div class="card-body">
                                <p class="card-text">Финансовые отчеты и аналитика</p>
                                <div class="d-grid">
                                    <a asp-controller="Reports" asp-action="Index" class="btn btn-outline-warning">
                                        <i class="fas fa-chart-line me-1"></i> Просмотреть
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <!-- Для сотрудников -->
                @if (User.IsInRole("Employee"))
                {
                    <div class="col-md-4 mb-4">
                        <div class="card border-danger h-100 shadow-sm">
                            <div class="card-header bg-danger text-white">
                                <h5 class="mb-0"><i class="fas fa-clock me-2"></i> Смена статусов</h5>
                            </div>
                            <div class="card-body">
                                <p class="card-text">Быстрое изменение статусов заказов</p>
                                <div class="d-grid">
                                    <a asp-controller="ServiceOrders" asp-action="Index" class="btn btn-outline-danger">
                                        <i class="fas fa-sync-alt me-1"></i> Обновить статусы
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- Сервисы и услуги -->
<section class="services-section py-5 bg-light">
    <div class="container">
        <h2 class="text-center mb-5">
            <i class="fas fa-concierge-bell text-primary me-2"></i> Наши услуги
        </h2>

        <div class="row g-4">
            <div class="col-md-3 col-6">
                <div class="service-item text-center p-3">
                    <div class="service-icon bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                         style="width: 70px; height: 70px;">
                        <i class="fas fa-laptop-medical fa-2x"></i>
                    </div>
                    <h5>Диагностика</h5>
                    <p class="text-muted small">Бесплатная диагностика неисправностей</p>
                </div>
            </div>

            <div class="col-md-3 col-6">
                <div class="service-item text-center p-3">
                    <div class="service-icon bg-success text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                         style="width: 70px; height: 70px;">
                        <i class="fas fa-tools fa-2x"></i>
                    </div>
                    <h5>Ремонт</h5>
                    <p class="text-muted small">Качественный ремонт любой сложности</p>
                </div>
            </div>

            <div class="col-md-3 col-6">
                <div class="service-item text-center p-3">
                    <div class="service-icon bg-info text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                         style="width: 70px; height: 70px;">
                        <i class="fas fa-database fa-2x"></i>
                    </div>
                    <h5>Восстановление данных</h5>
                    <p class="text-muted small">Спасение важной информации</p>
                </div>
            </div>

            <div class="col-md-3 col-6">
                <div class="service-item text-center p-3">
                    <div class="service-icon bg-warning text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                         style="width: 70px; height: 70px;">
                        <i class="fas fa-shield-alt fa-2x"></i>
                    </div>
                    <h5>Обслуживание</h5>
                    <p class="text-muted small">Профилактика и чистка техники</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Преимущества -->
<section class="benefits-section py-5">
    <div class="container">
        <h2 class="text-center mb-5">
            <i class="fas fa-award text-success me-2"></i> Почему выбирают нас?
        </h2>

        <div class="row">
            <div class="col-lg-4 mb-4">
                <div class="benefit-card p-4 border rounded shadow-sm h-100">
                    <div class="benefit-icon mb-3">
                        <i class="fas fa-bolt fa-2x text-warning"></i>
                    </div>
                    <h4>Быстро</h4>
                    <p class="text-muted">Среднее время ремонта - 2-3 часа. Срочный ремонт за 1 час.</p>
                </div>
            </div>

            <div class="col-lg-4 mb-4">
                <div class="benefit-card p-4 border rounded shadow-sm h-100">
                    <div class="benefit-icon mb-3">
                        <i class="fas fa-gem fa-2x text-primary"></i>
                    </div>
                    <h4>Качественно</h4>
                    <p class="text-muted">Используем только оригинальные запчасти и оборудование.</p>
                </div>
            </div>

            <div class="col-lg-4 mb-4">
                <div class="benefit-card p-4 border rounded shadow-sm h-100">
                    <div class="benefit-icon mb-3">
                        <i class="fas fa-shield-alt fa-2x text-success"></i>
                    </div>
                    <h4>С гарантией</h4>
                    <p class="text-muted">Гарантия на все виды работ до 2 лет. Бесплатная постгарантийная поддержка.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Контакты -->
<section class="contact-section py-5 bg-dark text-white">
    <div class="container">
        <div class="row">
            <div class="col-lg-4 mb-4">
                <h4><i class="fas fa-map-marker-alt me-2"></i> Наш адрес</h4>
                <p class="mb-0">г. Москва, ул. Техническая, д. 15</p>
                <p class="text-muted">Ежедневно с 9:00 до 21:00</p>
            </div>

            <div class="col-lg-4 mb-4">
                <h4><i class="fas fa-phone me-2"></i> Контакты</h4>
                <p class="mb-1">
                    <i class="fas fa-phone-alt me-2"></i> +7 (495) 123-45-67
                </p>
                <p class="mb-0">
                    <i class="fas fa-envelope me-2"></i> info@computerservice.ru
                </p>
            </div>

            <div class="col-lg-4 mb-4">
                <h4><i class="fas fa-clock me-2"></i> Режим работы</h4>
                <p class="mb-1">Пн-Пт: 9:00 - 21:00</p>
                <p class="mb-1">Сб-Вс: 10:00 - 18:00</p>
                <p class="text-muted">Без перерыва на обед</p>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        /* Стили для главной страницы */
        .hero-section {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 0 0 20px 20px;
        }

        .service-card, .order-card, .tech-card {
            transition: transform 0.3s, box-shadow 0.3s;
            border: none;
            border-radius: 15px;
        }

            .service-card:hover, .order-card:hover, .tech-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            }

        .service-card {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            color: white;
        }

        .order-card {
            background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
            color: white;
        }

        .tech-card {
            background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
            color: white;
        }

        .stats-section {
            margin-top: -30px;
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        .service-item {
            transition: all 0.3s;
        }

            .service-item:hover {
                background-color: white;
                border-radius: 10px;
                box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            }

        .benefit-card {
            transition: all 0.3s;
        }

            .benefit-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            }

        .contact-section {
            border-radius: 20px 20px 0 0;
        }

        /* Адаптивность */
        @@media (max-width: 768px) {
            .hero-section {
                padding: 3rem 1rem;
            }

            .display-4 {
                font-size: 2.5rem;
            }

            .stat-number {
                font-size: 1.8rem;
            }
        }
    </style>
}

@section Scripts {
    <script>
        // Анимация для счетчиков статистики
        document.addEventListener('DOMContentLoaded', function() {
            const statNumbers = document.querySelectorAll('.stat-number');

            statNumbers.forEach(stat => {
                const originalText = stat.textContent;
                const number = parseInt(originalText.replace(/\D/g, ''));

                if (!isNaN(number)) {
                    animateCounter(stat, number);
                }
            });

            function animateCounter(element, target) {
                let current = 0;
                const increment = target / 50;
                const timer = setInterval(() => {
                    current += increment;
                    if (current >= target) {
                        current = target;
                        clearInterval(timer);
                    }
                    element.textContent = Math.floor(current);
                }, 30);
            }
        });

        // Плавная прокрутка для якорных ссылок
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const targetId = this.getAttribute('href');
                if (targetId === '#') return;

                const targetElement = document.querySelector(targetId);
                if (targetElement) {
                    window.scrollTo({
                        top: targetElement.offsetTop - 80,
                        behavior: 'smooth'
                    });
                }
            });
        });
    </script>
}