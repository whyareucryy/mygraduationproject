@model ComputerRepairService.Models.Entities.Customer

@{
    ViewData["Title"] = "Детали клиента";
}

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4 class="card-title mb-0">
                    <i class="fas fa-user"></i> Детали клиента
                </h4>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">Имя:</dt>
                    <dd class="col-sm-9">@Model.FirstName</dd>

                    <dt class="col-sm-3">Фамилия:</dt>
                    <dd class="col-sm-9">@Model.LastName</dd>

                    <dt class="col-sm-3">Email:</dt>
                    <dd class="col-sm-9">@Model.Email</dd>

                    <dt class="col-sm-3">Телефон:</dt>
                    <dd class="col-sm-9">@Model.Phone</dd>

                    <dt class="col-sm-3">Адрес:</dt>
                    <dd class="col-sm-9">@Model.Address</dd>

                    <dt class="col-sm-3">Дата регистрации:</dt>
                    <dd class="col-sm-9">@Model.RegistrationDate.ToString("dd.MM.yyyy HH:mm")</dd>

                    <dt class="col-sm-3">Статус:</dt>
                    <dd class="col-sm-9">
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success">Активен</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Неактивен</span>
                        }
                    </dd>
                </dl>

                <div class="mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.CustomerId" class="btn btn-warning">
                        <i class="fas fa-edit"></i> Редактировать
                    </a>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Назад к списку
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Статистика заказов</h5>
            </div>
            <div class="card-body">
                @if (Model.ServiceOrders.Any())
                {
                    <div class="text-center">
                        <h3 class="text-primary">@Model.ServiceOrders.Count</h3>
                        <p class="text-muted">Всего заказов</p>
                    </div>

                    <div class="mt-3">
                        <h6>Последние заказы:</h6>
                        <ul class="list-group list-group-flush">
                            @foreach (var order in Model.ServiceOrders.Take(3))
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <small>@order.ProblemDescription.Substring(0, Math.Min(30, order.ProblemDescription.Length))...</small>
                                    <span class="badge bg-secondary">@order.OrderStatus?.StatusName</span>
                                </li>
                            }
                        </ul>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted">
                        <i class="fas fa-clipboard-list fa-2x mb-2"></i>
                        <p>Нет заказов</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>