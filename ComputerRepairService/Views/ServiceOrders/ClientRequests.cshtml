@model IEnumerable<ComputerRepairService.Models.Entities.ServiceOrder>

@{
    ViewData["Title"] = "Заявки клиентов";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-inbox"></i> Входящие заявки клиентов</h2>
    <div class="btn-group">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-list"></i> Все заказы
        </a>
        <a asp-action="Create" class="btn btn-success">
            <i class="fas fa-plus"></i> Создать заказ
        </a>
    </div>
</div>

<div class="alert alert-info">
    <i class="fas fa-info-circle me-1"></i>
    Здесь отображаются новые заявки, созданные клиентами. Откройте заявку и заполните служебные поля через "Редактировать".
</div>

<div class="row mb-3">
    <div class="col-md-4">
        <div class="card bg-primary text-white">
            <div class="card-body text-center py-3">
                <h4 class="mb-1">@Model.Count()</h4>
                <p class="mb-0 small">Новых заявок</p>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Дата</th>
                            <th>Клиент</th>
                            <th>Устройство</th>
                            <th>Описание проблемы</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>#@item.OrderId</strong></td>
                                <td>@item.CreatedDate.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>
                                    @item.Customer?.FirstName @item.Customer?.LastName
                                    <br />
                                    <small class="text-muted">@item.Customer?.Phone</small>
                                </td>
                                <td>
                                    <span class="badge bg-secondary">@item.DeviceType?.TypeName</span>
                                    <br />
                                    <small>@item.DeviceBrand @item.DeviceModel</small>
                                </td>
                                <td>
                                    <div class="text-truncate" style="max-width: 320px;" title="@item.ProblemDescription">
                                        @item.ProblemDescription
                                    </div>
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <form asp-action="TakeInWork" asp-route-id="@item.OrderId" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-success" title="Взять в работу">
                                                <i class="fas fa-play"></i>
                                            </button>
                                        </form>
                                        <a asp-action="Details" asp-route-id="@item.OrderId" class="btn btn-info" title="Открыть">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.OrderId" class="btn btn-warning" title="Обработать заявку">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="ChangeStatus" asp-route-id="@item.OrderId" class="btn btn-secondary" title="Изменить статус">
                                            <i class="fas fa-sync-alt"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-4">
                <i class="fas fa-check-circle fa-3x text-success mb-3"></i>
                <h4>Новых заявок нет</h4>
                <p class="text-muted mb-0">Все клиентские заявки уже обработаны.</p>
            </div>
        }
    </div>
</div>
