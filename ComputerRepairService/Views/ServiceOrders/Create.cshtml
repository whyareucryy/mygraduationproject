@model ComputerRepairService.Models.Entities.ServiceOrder

@{
    ViewData["Title"] = "Создать заказ";
}

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title">Создать новый заказ</h4>
            </div>
            <div class="card-body">
                <!-- Добавим подробный вывод ошибок -->
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        <h5>Ошибки валидации:</h5>
                        <ul>
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        </ul>
                    </div>
                }

                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label class="form-label">Клиент *</label>
                                <select asp-for="CustomerId" class="form-select" required>
                                    <option value="">-- Выберите клиента --</option>
                                    @foreach (var customer in ViewBag.Customers)
                                    {
                                        <option value="@customer.CustomerId">@customer.FirstName @customer.LastName - @customer.Phone</option>
                                    }
                                </select>
                                <span asp-validation-for="CustomerId" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label class="form-label">Тип устройства *</label>
                                <select asp-for="DeviceTypeId" class="form-select" required>
                                    <option value="">-- Выберите тип устройства --</option>
                                    @foreach (var deviceType in ViewBag.DeviceTypes)
                                    {
                                        <option value="@deviceType.DeviceTypeId">@deviceType.TypeName</option>
                                    }
                                </select>
                                <span asp-validation-for="DeviceTypeId" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="DeviceBrand" class="form-label">Бренд устройства</label>
                                <input asp-for="DeviceBrand" class="form-control" />
                                <span asp-validation-for="DeviceBrand" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="DeviceModel" class="form-label">Модель устройства</label>
                                <input asp-for="DeviceModel" class="form-control" />
                                <span asp-validation-for="DeviceModel" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="SerialNumber" class="form-label">Серийный номер</label>
                                <input asp-for="SerialNumber" class="form-control" />
                                <span asp-validation-for="SerialNumber" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label class="form-label">Статус *</label>
                                <select asp-for="StatusId" class="form-select" required>
                                    @foreach (var status in ViewBag.Statuses)
                                    {
                                        <option value="@status.StatusId">@status.StatusName</option>
                                    }
                                </select>
                                <span asp-validation-for="StatusId" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label class="form-label">Приоритет *</label>
                                <select asp-for="Priority" class="form-select" required>
                                    <option value="1">Низкий</option>
                                    <option value="2" selected>Средний</option>
                                    <option value="3">Высокий</option>
                                    <option value="4">Срочный</option>
                                    <option value="5">Критичный</option>
                                </select>
                                <span asp-validation-for="Priority" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="EstimatedCompletionDate" class="form-label">Предполагаемая дата завершения</label>
                                <input asp-for="EstimatedCompletionDate" type="date" class="form-control" />
                                <span asp-validation-for="EstimatedCompletionDate" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="ProblemDescription" class="form-label">Описание проблемы *</label>
                        <textarea asp-for="ProblemDescription" class="form-control" rows="4" required></textarea>
                        <span asp-validation-for="ProblemDescription" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="DiagnosticNotes" class="form-label">Диагностические заметки</label>
                        <textarea asp-for="DiagnosticNotes" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="DiagnosticNotes" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="TechnicianNotes" class="form-label">Заметки мастера</label>
                        <textarea asp-for="TechnicianNotes" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="TechnicianNotes" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label">Назначить мастеров</label>
                        <select name="selectedTechnicians" class="form-select" multiple>
                            @foreach (var technician in ViewBag.Technicians)
                            {
                                <option value="@technician.TechnicianId">@technician.FirstName @technician.LastName - @technician.Specialization</option>
                            }
                        </select>
                        <small class="form-text text-muted">Для выбора нескольких мастеров удерживайте Ctrl</small>
                    </div>

                    <div class="form-group">
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-save"></i> Создать заказ
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Назад к списку
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Отладочная информация в консоль
        console.log('Customers count: @ViewBag.Customers?.Count');
        console.log('DeviceTypes count: @ViewBag.DeviceTypes?.Count');
        console.log('Statuses count: @ViewBag.Statuses?.Count');
        console.log('Technicians count: @ViewBag.Technicians?.Count');
    </script>
}