@model IEnumerable<ComputerRepairService.Models.Entities.ServiceOrder>

@{
    ViewData["Title"] = "Мои задачи";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-tasks"></i> Мои задачи</h2>
        <div class="btn-group">
            <button type="button" class="btn btn-outline-primary dropdown-toggle" data-bs-toggle="dropdown">
                <i class="fas fa-filter"></i> Фильтр
            </button>
            <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="#" onclick="filterOrders('all')">Все задачи</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item" href="#" onclick="filterOrders('active')">Активные</a></li>
                <li><a class="dropdown-item" href="#" onclick="filterOrders('diagnostics')">Диагностика</a></li>
                <li><a class="dropdown-item" href="#" onclick="filterOrders('repair')">В ремонте</a></li>
            </ul>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body text-center py-3">
                    <h4 class="card-title mb-1">@Model.Count()</h4>
                    <p class="card-text small mb-0">Всего задач</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-dark">
                <div class="card-body text-center py-3">
                    <h4 class="card-title mb-1">@Model.Count(o => o.OrderStatus?.StatusName == "Диагностика")</h4>
                    <p class="card-text small mb-0">На диагностике</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body text-center py-3">
                    <h4 class="card-title mb-1">@Model.Count(o => o.OrderStatus?.StatusName == "В ремонте")</h4>
                    <p class="card-text small mb-0">В ремонте</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-danger text-white">
                <div class="card-body text-center py-3">
                    <h4 class="card-title mb-1">@Model.Count(o => o.Priority == 3)</h4>
                    <p class="card-text small mb-0">Высокий приоритет</p>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-info">
            <div class="card-body text-center py-5">
                <i class="fas fa-clipboard-check fa-3x text-info mb-3"></i>
                <h4 class="card-title">У вас нет назначенных задач</h4>
                <p class="card-text">Все задачи выполнены или ожидают назначения</p>
                <a asp-controller="ServiceOrders" asp-action="Index" class="btn btn-primary">
                    <i class="fas fa-list"></i> Просмотреть все заказы
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover" id="ordersTable">
                <thead class="table-light">
                    <tr>
                        <th>№</th>
                        <th>Клиент</th>
                        <th>Устройство</th>
                        <th>Проблема</th>
                        <th>Статус</th>
                        <th>Приоритет</th>
                        <th>Дата создания</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model.OrderByDescending(o => o.Priority).ThenByDescending(o => o.CreatedDate))
                    {
                        <tr data-status="@order.OrderStatus?.StatusName?.ToLower()">
                            <td><strong>#@order.OrderId</strong></td>
                            <td>
                                @if (order.Customer != null)
                                {
                                    <div>
                                        @order.Customer.FirstName @order.Customer.LastName
                                        <br>
                                        <small class="text-muted">@order.Customer.Phone</small>
                                    </div>
                                }
                            </td>
                            <td>
                                @if (order.DeviceType != null)
                                {
                                    <span class="badge bg-secondary">@order.DeviceType.TypeName</span>
                                }
                                <br>
                                <small>@order.DeviceBrand @order.DeviceModel</small>
                            </td>
                            <td>
                                <div class="problem-description">
                                    @(order.ProblemDescription.Length > 80 ? order.ProblemDescription.Substring(0, 80) + "..." : order.ProblemDescription)
                                </div>
                            </td>
                            <td>
                                <partial name="_OrderStatusBadge" model="order.OrderStatus?.StatusName" />
                            </td>
                            <td>
                                @switch (order.Priority)
                                {
                                    case 1:
                                        <span class="badge bg-success">Низкий</span>
                                        ; break;
                                    case 2:

                                        <span class="badge bg-warning text-dark">Средний</span>
                                        ; break;
                                    case 3:

                                        <span class="badge bg-danger">Высокий</span>
                                        ; break;
                                    default:

                                        <span class="badge bg-secondary">Не указан</span>
                                        ; break;
                                }
                            </td>
                            <td>@order.CreatedDate.ToString("dd.MM.yyyy")</td>
                            <td>
                                <div class="btn-group btn-group-sm" role="group">
                                    <a asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-info" title="Просмотреть">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@order.OrderId" class="btn btn-warning" title="Редактировать">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="ChangeStatus" asp-route-id="@order.OrderId" class="btn btn-primary" title="Изменить статус">
                                        <i class="fas fa-sync-alt"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Фильтрация задач
        function filterOrders(filter) {
            const rows = document.querySelectorAll('#ordersTable tbody tr');

            rows.forEach(row => {
                const status = row.getAttribute('data-status');
                let show = true;

                switch(filter) {
                    case 'active':
                        show = status === 'диагностика' || status === 'в ремонте' || status === 'ожидание запчастей';
                        break;
                    case 'diagnostics':
                        show = status === 'диагностика';
                        break;
                    case 'repair':
                        show = status === 'в ремонте';
                        break;
                    // 'all' - показываем все
                }

                row.style.display = show ? '' : 'none';
            });
        }

        // Автоматическое скрытие уведомлений
        setTimeout(function() {
            $('.alert').alert('close');
        }, 5000);
    </script>
}