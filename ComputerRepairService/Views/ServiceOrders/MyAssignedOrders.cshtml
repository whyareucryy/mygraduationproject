@model IEnumerable<ComputerRepairService.Models.Entities.ServiceOrder>
@using ComputerRepairService.Services

@{
    ViewData["Title"] = "Мои задачи";

    var orders = Model
        .OrderByDescending(o => o.Priority)
        .ThenByDescending(o => o.CreatedDate)
        .ToList();

    var activeStatuses = new[] { "Новая", "Диагностика", "Ожидание запчастей", "В ремонте" };

    var totalOrders = orders.Count;
    var activeOrdersList = orders.Where(o => o.StatusId != ComputerRepairService.Models.Enums.OrderStatusIds.Issued && o.StatusId != ComputerRepairService.Models.Enums.OrderStatusIds.Cancelled).ToList();
    var completedOrdersList = orders.Where(o => o.StatusId == ComputerRepairService.Models.Enums.OrderStatusIds.Issued || o.StatusId == ComputerRepairService.Models.Enums.OrderStatusIds.Cancelled).ToList();

    var activeOrdersCount = activeOrdersList.Count;
    var diagnosticOrders = orders.Count(o => (o.OrderStatus?.StatusName ?? string.Empty) == "Диагностика");
    var highPriorityOrders = activeOrdersList.Count(o => o.Priority >= 3);

    string GetPriorityText(int priority) => priority switch
    {
        <= 0 => "Не указан",
        1 => "Низкий",
        2 => "Средний",
        3 => "Высокий",
        4 => "Срочный",
        _ => "Критичный"
    };

    string GetPriorityClass(int priority) => priority switch
    {
        <= 0 => "bg-secondary",
        1 => "bg-success",
        2 => "bg-info",
        3 => "bg-warning text-dark",
        4 => "bg-danger",
        _ => "bg-dark"
    };
}

<div class="container mt-4">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
        <h2 class="mb-0"><i class="fas fa-tasks"></i> Мои задачи</h2>

        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-list"></i> Все заказы
            </a>
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-outline-primary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="fas fa-filter"></i> Фильтр
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" href="#" onclick="filterOrders('all'); return false;">Все задачи</a></li>
                    <li><a class="dropdown-item" href="#" onclick="filterOrders('active'); return false;">Активные</a></li>
                    <li><a class="dropdown-item" href="#" onclick="filterOrders('diagnostics'); return false;">Диагностика</a></li>
                    <li><a class="dropdown-item" href="#" onclick="filterOrders('repair'); return false;">В ремонте</a></li>
                    <li><a class="dropdown-item" href="#" onclick="filterOrders('highpriority'); return false;">Высокий приоритет</a></li>
                </ul>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card bg-primary text-white h-100">
                <div class="card-body text-center py-3">
                    <h4 class="card-title mb-1">@totalOrders</h4>
                    <p class="card-text small mb-0">Всего задач</p>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card bg-warning text-dark h-100">
                <div class="card-body text-center py-3">
                    <h4 class="card-title mb-1">@activeOrdersCount</h4>
                    <p class="card-text small mb-0">Активные</p>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card bg-info text-white h-100">
                <div class="card-body text-center py-3">
                    <h4 class="card-title mb-1">@diagnosticOrders</h4>
                    <p class="card-text small mb-0">На диагностике</p>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card bg-danger text-white h-100">
                <div class="card-body text-center py-3">
                    <h4 class="card-title mb-1">@highPriorityOrders</h4>
                    <p class="card-text small mb-0">Высокий приоритет</p>
                </div>
            </div>
        </div>
    </div>

    @if (!orders.Any())
    {
        <div class="card border-info shadow-sm">
            <div class="card-body text-center py-5">
                <i class="fas fa-clipboard-check fa-3x text-info mb-3"></i>
                <h4 class="card-title">У вас нет назначенных задач</h4>
                <p class="card-text text-muted">Проверьте общий список заказов или дождитесь новых назначений.</p>
                <a asp-action="Index" class="btn btn-primary">
                    <i class="fas fa-list"></i> Перейти к списку заказов
                </a>
            </div>
        </div>
    }
    else
    {
        <ul class="nav nav-tabs mb-4" id="ordersTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active fw-bold" id="active-tab" data-bs-toggle="tab" data-bs-target="#active-orders" type="button" role="tab" aria-controls="active-orders" aria-selected="true">
                    Актуальные <span class="badge bg-primary ms-1">@activeOrdersList.Count</span>
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold" id="completed-tab" data-bs-toggle="tab" data-bs-target="#completed-orders" type="button" role="tab" aria-controls="completed-orders" aria-selected="false">
                    Завершенные <span class="badge bg-secondary ms-1">@completedOrdersList.Count</span>
                </button>
            </li>
        </ul>

        <div class="tab-content" id="ordersTabsContent">
            <!-- Вкладка: Актуальные заказы -->
            <div class="tab-pane fade show active" id="active-orders" role="tabpanel" aria-labelledby="active-tab">
                <div class="card shadow-sm">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0" id="ordersTable">
                                <thead class="table-dark">
                                    <tr>
                                        <th>№</th>
                                        <th>Клиент</th>
                                        <th>Устройство</th>
                                        <th>Проблема</th>
                                        <th>Статус</th>
                                        <th>Приоритет</th>
                                        <th>Дата создания</th>
                                        <th class="text-end">Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!activeOrdersList.Any())
                                    {
                                        <tr>
                                            <td colspan="8" class="text-center py-4 text-muted">Нет актуальных заказов</td>
                                        </tr>
                                    }
                                    @foreach (var order in activeOrdersList)
                                    {
                                        var statusName = order.OrderStatus?.StatusName ?? "Неизвестно";
                                        var problemText = order.ProblemDescription ?? string.Empty;
                                        var deviceType = order.DeviceType?.TypeName ?? "Не указан";
                                        var deviceLabel = string.Join(" ", new[] { order.DeviceBrand, order.DeviceModel }.Where(v => !string.IsNullOrWhiteSpace(v)));
                                        var customerName = order.Customer != null
                                            ? $"{order.Customer.FirstName} {order.Customer.LastName}".Trim()
                                            : "Клиент не указан";

                                        <tr data-status="@statusName.ToLower()" data-priority="@order.Priority">
                                            <td><strong>#@order.OrderId</strong></td>
                                            <td>
                                                <div class="fw-semibold">@customerName</div>
                                                @if (!string.IsNullOrWhiteSpace(order.Customer?.Phone))
                                                {
                                                    <small class="text-muted">@order.Customer.Phone</small>
                                                }
                                            </td>
                                            <td>
                                                <span class="badge bg-secondary">@deviceType</span>
                                                <div class="small mt-1">@(string.IsNullOrWhiteSpace(deviceLabel) ? "Модель не указана" : deviceLabel)</div>
                                            </td>
                                            <td>
                                                <div class="text-truncate" style="max-width: 280px;" title="@problemText">
                                                    @(problemText.Length > 120 ? problemText.Substring(0, 120) + "..." : problemText)
                                                </div>
                                            </td>
                                            <td>
                                                <partial name="_OrderStatusBadge" model="statusName" />
                                            </td>
                                            <td>
                                                <span class="badge @GetPriorityClass(order.Priority)">@GetPriorityText(order.Priority)</span>
                                            </td>
                                            <td>@order.CreatedDate.ToString("dd.MM.yyyy")</td>
                                            <td class="text-end">
                                                <div class="btn-group btn-group-sm" role="group">
                                                    <a asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-info" title="Детали">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    @if (ComputerRepairService.Services.OrderPaymentHelper.CanIssueDevice(order))
                                                    {
                                                        <a asp-action="IssueOrder" asp-route-id="@order.OrderId" class="btn btn-primary" title="Выдать устройство">
                                                            <i class="fas fa-box-open"></i>
                                                        </a>
                                                    }
                                                    else if (OrderPaymentHelper.CanEmployeeComplete(order))
                                                    {
                                                        <a asp-action="CompleteOrder" asp-route-id="@order.OrderId" class="btn btn-success" title="Заказ выполнен">
                                                            <i class="fas fa-check-double"></i>
                                                        </a>
                                                    }
                                                    <a asp-action="Edit" asp-route-id="@order.OrderId" class="btn btn-warning" title="Редактировать">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Вкладка: Завершенные заказы -->
            <div class="tab-pane fade" id="completed-orders" role="tabpanel" aria-labelledby="completed-tab">
                <div class="card shadow-sm opacity-75">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0" id="completedOrdersTable">
                                <thead class="table-light text-muted">
                                    <tr>
                                        <th>№</th>
                                        <th>Клиент</th>
                                        <th>Устройство</th>
                                        <th>Статус</th>
                                        <th>Дата создания</th>
                                        <th>Дата завершения</th>
                                        <th class="text-end">Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!completedOrdersList.Any())
                                    {
                                        <tr>
                                            <td colspan="7" class="text-center py-4 text-muted">Нет завершенных заказов</td>
                                        </tr>
                                    }
                                    @foreach (var order in completedOrdersList)
                                    {
                                        var statusName = order.OrderStatus?.StatusName ?? "Неизвестно";
                                        var deviceType = order.DeviceType?.TypeName ?? "Не указан";
                                        var customerName = order.Customer != null
                                            ? $"{order.Customer.FirstName} {order.Customer.LastName}".Trim()
                                            : "Клиент не указан";

                                        <tr>
                                            <td class="text-muted">#@order.OrderId</td>
                                            <td>
                                                <div class="fw-semibold">@customerName</div>
                                            </td>
                                            <td>
                                                <span class="badge bg-secondary">@deviceType</span>
                                            </td>
                                            <td>
                                                <partial name="_OrderStatusBadge" model="statusName" />
                                            </td>
                                            <td class="text-muted">@order.CreatedDate.ToString("dd.MM.yyyy")</td>
                                            <td class="text-muted">
                                                @(order.ActualCompletionDate?.ToString("dd.MM.yyyy") ?? "—")
                                            </td>
                                            <td class="text-end">
                                                <a asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-sm btn-outline-info" title="Детали">
                                                    <i class="fas fa-eye"></i> Детали
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function filterOrders(filter) {
            const rows = document.querySelectorAll('#ordersTable tbody tr');

            rows.forEach(row => {
                const status = (row.dataset.status || '').toLowerCase();
                const priority = parseInt(row.dataset.priority || '0', 10);

                let show = true;
                switch (filter) {
                    case 'active':
                        show = status === 'новая' || status === 'диагностика' || status === 'ожидание запчастей' || status === 'в ремонте';
                        break;
                    case 'diagnostics':
                        show = status === 'диагностика';
                        break;
                    case 'repair':
                        show = status === 'в ремонте';
                        break;
                    case 'highpriority':
                        show = priority >= 3;
                        break;
                    default:
                        show = true;
                        break;
                }

                row.style.display = show ? '' : 'none';
            });
        }

        setTimeout(function () {
            $('.alert').alert('close');
        }, 5000);
    </script>
}
