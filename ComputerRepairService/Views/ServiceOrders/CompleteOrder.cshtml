@model ComputerRepairService.Models.ViewModels.CompleteOrderViewModel

@{
    ViewData["Title"] = $"Завершение заказа #{Model.OrderId}";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="MyAssignedOrders">Мои задачи</a></li>
            <li class="breadcrumb-item active">Заказ #@Model.OrderId</li>
        </ol>
    </nav>

    <h2 class="mb-4"><i class="fas fa-check-double"></i> Заказ выполнен</h2>

    <div class="alert alert-info">
        <i class="fas fa-info-circle"></i>
        Укажите итоговую стоимость работ. Заказ перейдёт в статус <strong>«Ожидание оплаты»</strong>, и клиент сможет оплатить его в личном кабинете.
    </div>

    <div class="row">
        <div class="col-lg-8">
            <form asp-action="CompleteOrder" asp-route-id="@Model.OrderId" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="OrderId" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Параметры заказа</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Клиент</dt>
                            <dd class="col-sm-8">@Model.CustomerName</dd>
                            <dt class="col-sm-4">Устройство</dt>
                            <dd class="col-sm-8">@Model.DeviceDescription</dd>
                            <dt class="col-sm-4">Статус</dt>
                            <dd class="col-sm-8"><span class="badge bg-secondary">@Model.CurrentStatusName</span></dd>
                            <dt class="col-sm-4">Проблема</dt>
                            <dd class="col-sm-8">@Model.ProblemDescription</dd>
                        </dl>
                    </div>
                </div>

                <div class="card mb-4 shadow-sm border-success">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">Стоимость и комментарий</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="TotalCost" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="TotalCost" class="form-control form-control-lg" type="number" step="0.01" min="0.01" />
                                <span class="input-group-text">₽</span>
                            </div>
                            <span asp-validation-for="TotalCost" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="TechnicianNotes" class="form-label"></label>
                            <textarea asp-for="TechnicianNotes" class="form-control" rows="4" placeholder="Что было сделано, рекомендации клиенту..."></textarea>
                            <span asp-validation-for="TechnicianNotes" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success btn-lg">
                        <i class="fas fa-paper-plane"></i> Отправить на оплату
                    </button>
                    <a asp-action="MyAssignedOrders" class="btn btn-outline-secondary btn-lg">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
