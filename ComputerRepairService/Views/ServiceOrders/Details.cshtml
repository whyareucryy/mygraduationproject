@model ComputerRepairService.Models.Entities.ServiceOrder

@{
    ViewData["Title"] = "Детали заказа";
}

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4 class="card-title mb-0">
                    <i class="fas fa-clipboard-list"></i> Детали заказа #@Model.OrderId
                </h4>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">Клиент:</dt>
                    <dd class="col-sm-9">@Model.Customer?.FirstName @Model.Customer?.LastName</dd>

                    <dt class="col-sm-3">Email:</dt>
                    <dd class="col-sm-9">@Model.Customer?.Email</dd>

                    <dt class="col-sm-3">Телефон:</dt>
                    <dd class="col-sm-9">@Model.Customer?.Phone</dd>

                    <dt class="col-sm-3">Тип устройства:</dt>
                    <dd class="col-sm-9">@Model.DeviceType?.TypeName</dd>

                    <dt class="col-sm-3">Бренд/Модель:</dt>
                    <dd class="col-sm-9">@Model.DeviceBrand @Model.DeviceModel</dd>

                    <dt class="col-sm-3">Серийный номер:</dt>
                    <dd class="col-sm-9">@Model.SerialNumber</dd>

                    <dt class="col-sm-3">Статус:</dt>
                    <dd class="col-sm-9">
                        <span class="badge bg-secondary">@Model.OrderStatus?.StatusName</span>
                    </dd>

                    <dt class="col-sm-3">Приоритет:</dt>
                    <dd class="col-sm-9">
                        @{
                            var priorityText = Model.Priority switch
                            {
                                1 => "Низкий",
                                2 => "Средний",
                                3 => "Высокий",
                                4 => "Срочный",
                                5 => "Критичный",
                                _ => "Неизвестно"
                            };
                        }
                        <span class="badge bg-warning text-dark">@priorityText</span>
                    </dd>

                    <dt class="col-sm-3">Дата создания:</dt>
                    <dd class="col-sm-9">@Model.CreatedDate.ToString("dd.MM.yyyy HH:mm")</dd>

                    <dt class="col-sm-3">Предполагаемое завершение:</dt>
                    <dd class="col-sm-9">
                        @if (Model.EstimatedCompletionDate.HasValue)
                        {
                            @Model.EstimatedCompletionDate.Value.ToString("dd.MM.yyyy")
                        }
                        else
                        {
                            <span class="text-muted">Не указана</span>
                        }
                    </dd>

                    <dt class="col-sm-3">Фактическое завершение:</dt>
                    <dd class="col-sm-9">
                        @if (Model.ActualCompletionDate.HasValue)
                        {
                            @Model.ActualCompletionDate.Value.ToString("dd.MM.yyyy HH:mm")
                        }
                        else
                        {
                            <span class="text-muted">Не завершен</span>
                        }
                    </dd>

                    <dt class="col-sm-3">Итоговая стоимость:</dt>
                    <dd class="col-sm-9">
                        <span class="fw-bold text-white bg-success rounded px-2 py-1 d-inline-block">@Model.TotalCost.ToString("C")</span>
                    </dd>
                </dl>

                <div class="mt-3">
                    <h5>Описание проблемы:</h5>
                    <p class="card-text">@Model.ProblemDescription</p>
                </div>

                @if (!string.IsNullOrEmpty(Model.DiagnosticNotes))
                {
                    <div class="mt-3">
                        <h5>Диагностические заметки:</h5>
                        <p class="card-text">@Model.DiagnosticNotes</p>
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.TechnicianNotes))
                {
                    <div class="mt-3">
                        <h5>Заметки мастера:</h5>
                        <p class="card-text">@Model.TechnicianNotes</p>
                    </div>
                }

                <div class="mt-4 d-flex flex-wrap gap-2">
                    @if (ComputerRepairService.Services.OrderPaymentHelper.CanEmployeeComplete(Model) || Model.StatusId == ComputerRepairService.Models.Enums.OrderStatusIds.New)
                    {
                        <button type="button" class="btn btn-warning" data-bs-toggle="modal" data-bs-target="#requireApprovalModal">
                            <i class="fas fa-hand-holding-usd"></i> На согласование
                        </button>
                    }
                    
                    @if (ComputerRepairService.Services.OrderPaymentHelper.CanEmployeeComplete(Model))
                    {
                        <a asp-action="CompleteOrder" asp-route-id="@Model.OrderId" class="btn btn-success">
                            <i class="fas fa-check-circle"></i> Завершить ремонт
                        </a>
                    }
                    
                    @if (ComputerRepairService.Services.OrderPaymentHelper.CanIssueDevice(Model))
                    {
                        <a asp-action="IssueOrder" asp-route-id="@Model.OrderId" class="btn btn-primary">
                            <i class="fas fa-box-open"></i> Выдать устройство
                        </a>
                    }

                    <a asp-action="Edit" asp-route-id="@Model.OrderId" class="btn btn-outline-warning">
                        <i class="fas fa-edit"></i> Редактировать
                    </a>
                    <a asp-action="ChangeStatus" asp-route-id="@Model.OrderId" class="btn btn-outline-info">
                        <i class="fas fa-sync-alt"></i> Изменить статус
                    </a>
                    <a asp-action="MyAssignedOrders" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left"></i> Назад
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Модальное окно для "На согласование" -->
    <div class="modal fade" id="requireApprovalModal" tabindex="-1" aria-labelledby="requireApprovalModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <form asp-action="RequireApproval" asp-route-id="@Model.OrderId" method="post" class="modal-content">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="requireApprovalModalLabel">Запросить согласование</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Клиенту будет отправлено уведомление для подтверждения стоимости ремонта.</p>
                    <div class="mb-3">
                        <label for="estimatedCost" class="form-label">Предварительная стоимость (₽)</label>
                        <input type="number" class="form-control" id="estimatedCost" name="estimatedCost" min="0" step="0.01" required>
                    </div>
                    <div class="mb-3">
                        <label for="notes" class="form-label">Комментарий для клиента (диагностика)</label>
                        <textarea class="form-control" id="notes" name="notes" rows="3" required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-warning">Отправить на согласование</button>
                </div>
            </form>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Назначенные мастера</h5>
            </div>
            <div class="card-body">
                @if (Model.OrderTechnicians.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var orderTech in Model.OrderTechnicians)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                @orderTech.Technician?.FirstName @orderTech.Technician?.LastName
                                <span class="badge bg-light text-dark">@orderTech.AssignedDate.ToString("dd.MM.yy")</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted text-center mb-0">Мастера не назначены</p>
                }
            </div>
        </div>
    </div>
</div>