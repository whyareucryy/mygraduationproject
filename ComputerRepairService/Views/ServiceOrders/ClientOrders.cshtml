@model IEnumerable<ComputerRepairService.Models.Entities.ServiceOrder>
@using ComputerRepairService.Services

@{
    ViewData["Title"] = "Мои заказы";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-clipboard-list"></i> Мои заказы</h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus-circle"></i> Новый заказ
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="card border-info">
            <div class="card-body text-center py-5">
                <i class="fas fa-inbox fa-3x text-info mb-3"></i>
                <h4 class="card-title">У вас пока нет заказов</h4>
                <p class="card-text">Создайте свой первый заказ на ремонт</p>
                <a asp-action="Create" class="btn btn-primary btn-lg">
                    <i class="fas fa-plus"></i> Создать заказ
                </a>
            </div>
        </div>
    }
    else
    {
        var activeOrdersList = Model.Where(o => o.StatusId != ComputerRepairService.Models.Enums.OrderStatusIds.Issued && o.StatusId != ComputerRepairService.Models.Enums.OrderStatusIds.Cancelled).ToList();
        var historyOrdersList = Model.Where(o => o.StatusId == ComputerRepairService.Models.Enums.OrderStatusIds.Issued || o.StatusId == ComputerRepairService.Models.Enums.OrderStatusIds.Cancelled).ToList();

        <ul class="nav nav-tabs mb-4" id="clientOrdersTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active fw-bold" id="active-tab" data-bs-toggle="tab" data-bs-target="#active-orders" type="button" role="tab" aria-controls="active-orders" aria-selected="true">
                    Актуальные <span class="badge bg-primary ms-1">@activeOrdersList.Count</span>
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold" id="history-tab" data-bs-toggle="tab" data-bs-target="#history-orders" type="button" role="tab" aria-controls="history-orders" aria-selected="false">
                    История заказов <span class="badge bg-secondary ms-1">@historyOrdersList.Count</span>
                </button>
            </li>
        </ul>

        <div class="tab-content" id="clientOrdersTabsContent">
            <!-- Актуальные -->
            <div class="tab-pane fade show active" id="active-orders" role="tabpanel" aria-labelledby="active-tab">
                <div class="row">
                    @if (!activeOrdersList.Any())
                    {
                        <div class="col-12">
                            <div class="alert alert-light text-center py-4 text-muted">
                                Нет актуальных заказов
                            </div>
                        </div>
                    }
                    @foreach (var order in activeOrdersList)
                    {
                        <div class="col-md-6 col-lg-4 mb-4">
                            <div class="card h-100 shadow-sm border-primary border-opacity-25">
                                <div class="card-header d-flex justify-content-between align-items-center bg-white">
                                    <h5 class="mb-0">Заказ #@order.OrderId</h5>
                                    <partial name="_OrderStatusBadge" model="order.OrderStatus?.StatusName" />
                                </div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <h6 class="text-muted small">Устройство</h6>
                                        <div class="d-flex align-items-center">
                                            @if (order.DeviceType != null)
                                            {
                                                <span class="badge bg-secondary me-2">@order.DeviceType.TypeName</span>
                                            }
                                            <span>@order.DeviceBrand @order.DeviceModel</span>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <h6 class="text-muted small">Проблема</h6>
                                        <p class="card-text">@(order.ProblemDescription.Length > 100 ? order.ProblemDescription.Substring(0, 100) + "..." : order.ProblemDescription)</p>
                                    </div>

                                    <div class="row g-2 mb-3">
                                        <div class="col-6">
                                            <h6 class="text-muted small">Создан</h6>
                                            <p class="mb-0">@order.CreatedDate.ToString("dd.MM.yyyy")</p>
                                        </div>
                                        <div class="col-6">
                                            <h6 class="text-muted small">Стоимость</h6>
                                            <p class="mb-0 fw-bold">@(order.TotalCost > 0 ? order.TotalCost.ToString("C") : "Не рассчитана")</p>
                                        </div>
                                    </div>

                                    @if (order.OrderTechnicians != null && order.OrderTechnicians.Any())
                                    {
                                        <div class="mb-3">
                                            <h6 class="text-muted small">Мастер</h6>
                                            <p class="mb-0">
                                                @foreach (var tech in order.OrderTechnicians)
                                                {
                                                    <span class="badge bg-light text-dark">
                                                        @tech.Technician?.FirstName @tech.Technician?.LastName
                                                    </span>
                                                }
                                            </p>
                                        </div>
                                    }
                                </div>
                                <div class="card-footer bg-transparent border-top-0">
                                    <div class="d-grid gap-2">
                                        @if (OrderPaymentHelper.CanClientApprove(order))
                                        {
                                            <form asp-action="ApproveOrder" asp-route-id="@order.OrderId" method="post" class="m-0 d-grid">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-warning fw-bold">
                                                    <i class="fas fa-check-circle"></i> Согласовать
                                                </button>
                                            </form>
                                        }
                                        else if (OrderPaymentHelper.CanClientPay(order))
                                        {
                                            <a asp-action="UnpaidOrders" class="btn btn-success">
                                                <i class="fas fa-credit-card"></i> Оплатить
                                            </a>
                                        }
                                        <a asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-outline-primary">
                                            <i class="fas fa-eye"></i> Подробнее
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- История заказов -->
            <div class="tab-pane fade" id="history-orders" role="tabpanel" aria-labelledby="history-tab">
                <div class="row">
                    @if (!historyOrdersList.Any())
                    {
                        <div class="col-12">
                            <div class="alert alert-light text-center py-4 text-muted">
                                История заказов пуста
                            </div>
                        </div>
                    }
                    @foreach (var order in historyOrdersList)
                    {
                        <div class="col-md-6 col-lg-4 mb-4">
                            <div class="card h-100 shadow-sm opacity-75">
                                <div class="card-header d-flex justify-content-between align-items-center bg-light">
                                    <h5 class="mb-0 text-muted">Заказ #@order.OrderId</h5>
                                    <partial name="_OrderStatusBadge" model="order.OrderStatus?.StatusName" />
                                </div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <h6 class="text-muted small">Устройство</h6>
                                        <div class="d-flex align-items-center text-muted">
                                            @if (order.DeviceType != null)
                                            {
                                                <span class="badge bg-secondary me-2 opacity-75">@order.DeviceType.TypeName</span>
                                            }
                                            <span>@order.DeviceBrand @order.DeviceModel</span>
                                        </div>
                                    </div>

                                    <div class="row g-2 mb-3">
                                        <div class="col-6">
                                            <h6 class="text-muted small">Дата создания</h6>
                                            <p class="mb-0 text-muted">@order.CreatedDate.ToString("dd.MM.yyyy")</p>
                                        </div>
                                        <div class="col-6">
                                            <h6 class="text-muted small">Итого</h6>
                                            <p class="mb-0 fw-bold text-muted">@(order.TotalCost > 0 ? order.TotalCost.ToString("C") : "—")</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="card-footer bg-transparent border-top-0">
                                    <div class="d-grid gap-2">
                                        <a asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-outline-secondary">
                                            <i class="fas fa-eye"></i> Детали
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Статистика -->
        <div class="row mt-4">
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body text-center">
                        <h5 class="card-title">@Model.Count()</h5>
                        <p class="card-text">Всего заказов</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-dark">
                    <div class="card-body text-center">
                        <h5 class="card-title">@Model.Count(o => o.OrderStatus?.StatusName == "В ремонте" || o.OrderStatus?.StatusName == "Диагностика")</h5>
                        <p class="card-text">В работе</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body text-center">
                        <h5 class="card-title">@Model.Count(o => o.OrderStatus?.StatusName == "Готово к выдаче")</h5>
                        <p class="card-text">К выдаче</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body text-center">
                        <h5 class="card-title">@Model.Where(o => o.TotalCost > 0).Sum(o => o.TotalCost).ToString("C")</h5>
                        <p class="card-text">Общая стоимость</p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Автоматическое скрытие уведомлений через 5 секунд
        setTimeout(function() {
            $('.alert').alert('close');
        }, 5000);
    </script>
}