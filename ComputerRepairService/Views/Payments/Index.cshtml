@model IEnumerable<ComputerRepairService.Models.Entities.Payment>
@using ComputerRepairService.Services

@{
    ViewData["Title"] = "Платежи";
    Layout = "_Layout";
    var statusFilter = ViewBag.StatusFilter as string ?? string.Empty;
    var ordersAwaiting = ViewBag.OrdersAwaitingPayment as List<ComputerRepairService.Models.Entities.ServiceOrder> ?? new();
}

<div class="container mt-4">
    <h1 class="mb-4">Платежи</h1>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card mb-4 border-warning shadow-sm">
        <div class="card-header bg-warning text-dark">
            <h5 class="mb-0"><i class="fas fa-hourglass-half"></i> Заказы в ожидании оплаты</h5>
        </div>
        <div class="card-body">
            @if (!ordersAwaiting.Any())
            {
                <p class="text-muted mb-0">Нет заказов в статусе «Ожидание оплаты».</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Заказ</th>
                                <th>Клиент</th>
                                <th>Сумма</th>
                                <th class="text-end">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in ordersAwaiting)
                            {
                                var due = OrderPaymentHelper.GetAmountDue(order);
                                <tr>
                                    <td><strong>#@order.OrderId</strong></td>
                                    <td>@order.Customer?.FirstName @order.Customer?.LastName</td>
                                    <td class="fw-bold text-success">@due.ToString("C")</td>
                                    <td class="text-end">
                                        <a asp-action="Create" asp-route-orderId="@order.OrderId" class="btn btn-sm btn-primary">
                                            <i class="fas fa-cash-register"></i> Принять оплату
                                        </a>
                                        <form asp-action="ConfirmPayment" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="orderId" value="@order.OrderId" />
                                            <input type="hidden" name="paymentMethod" value="Cash" />
                                            <button type="submit" class="btn btn-sm btn-success" title="Наличные">
                                                <i class="fas fa-check"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <a asp-action="Create" class="btn btn-primary @(ordersAwaiting.Any() ? "" : "disabled")">
                <i class="fas fa-plus"></i> Добавить платёж
            </a>
            <small class="text-muted d-block mt-1">Только для заказов «Ожидание оплаты»</small>
        </div>
        <div class="col-md-6 text-end">
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">
                    <i class="fas fa-filter"></i> Фильтр по статусу
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item @(string.IsNullOrEmpty(statusFilter) ? "active" : null)" href="?status=">Все платежи</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item @(statusFilter == "Completed" ? "active" : null)" href="?status=Completed">Завершенные</a></li>
                    <li><a class="dropdown-item @(statusFilter == "Pending" ? "active" : null)" href="?status=Pending">Ожидающие</a></li>
                    <li><a class="dropdown-item @(statusFilter == "Failed" ? "active" : null)" href="?status=Failed">Ошибки</a></li>
                    <li><a class="dropdown-item @(statusFilter == "Refunded" ? "active" : null)" href="?status=Refunded">Возвраты</a></li>
                </ul>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Нет платежей. Начните с добавления нового платежа.
        </div>
    }
    else
    {
        <!-- Статистика -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body">
                        <h6 class="card-title">Завершенные</h6>
                        <h4>@Model.Count(p => p.Status == "Completed")</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-dark">
                    <div class="card-body">
                        <h6 class="card-title">Ожидающие</h6>
                        <h4>@Model.Count(p => p.Status == "Pending")</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-danger text-white">
                    <div class="card-body">
                        <h6 class="card-title">Ошибки</h6>
                        <h4>@Model.Count(p => p.Status == "Failed")</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body">
                        <h6 class="card-title">Общая сумма</h6>
                        <h4>@Model.Where(p => p.Status == "Completed").Sum(p => p.Amount).ToString("C")</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Заказ</th>
                        <th>Клиент</th>
                        <th>Сумма</th>
                        <th>Дата</th>
                        <th>Метод</th>
                        <th>Статус</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.PaymentId</td>
                            <td>
                                @if (item.ServiceOrder != null)
                                {
                                    <a asp-controller="ServiceOrders" asp-action="Details" asp-route-id="@item.OrderId">
                                        Заказ #@item.OrderId
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted">Заказ #@item.OrderId</span>
                                }
                            </td>
                            <td>
                                @if (item.ServiceOrder?.Customer != null)
                                {
                                    @($"{item.ServiceOrder.Customer.FirstName} {item.ServiceOrder.Customer.LastName}")
                                }
                                else
                                {
                                    <span class="text-muted">Неизвестно</span>
                                }
                            </td>
                            <td>@item.Amount.ToString("C")</td>
                            <td>@item.PaymentDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                @switch (item.PaymentMethod)
                                {
                                    case "Cash":
                                        <span class="badge bg-secondary"><i class="fas fa-money-bill"></i> Наличные</span>
                                        break;
                                    case "Card":
                                        <span class="badge bg-primary"><i class="fas fa-credit-card"></i> Карта</span>
                                        break;
                                    case "Bank Transfer":
                                        <span class="badge bg-info"><i class="fas fa-university"></i> Перевод</span>
                                        break;
                                    case "Online":
                                        <span class="badge bg-dark"><i class="fas fa-globe"></i> Онлайн</span>
                                        break;
                                    default:
                                        <span class="badge bg-light text-dark">@item.PaymentMethod</span>
                                        break;
                                }
                            </td>
                            <td>
                                @switch (item.Status)
                                {
                                    case "Completed":
                                        <span class="badge bg-success">Завершен</span>
                                        break;
                                    case "Pending":
                                        <span class="badge bg-warning">Ожидание</span>
                                        break;
                                    case "Failed":
                                        <span class="badge bg-danger">Ошибка</span>
                                        break;
                                    case "Refunded":
                                        <span class="badge bg-info">Возврат</span>
                                        break;
                                    default:
                                        <span class="badge bg-secondary">@item.Status</span>
                                        break;
                                }
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="Details" asp-route-id="@item.PaymentId"
                                       class="btn btn-sm btn-info" title="Подробнее">
                                        <i class="fas fa-info-circle"></i>
                                    </a>
                                    @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.PaymentId"
                                           class="btn btn-sm btn-warning" title="Редактировать">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                    }
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a asp-action="Delete" asp-route-id="@item.PaymentId"
                                           class="btn btn-sm btn-danger" title="Удалить">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Styles {
    <style>
        .card {
            transition: transform 0.2s;
        }

            .card:hover {
                transform: translateY(-5px);
            }

        .badge {
            font-size: 0.8em;
            padding: 0.4em 0.6em;
        }
    </style>
}