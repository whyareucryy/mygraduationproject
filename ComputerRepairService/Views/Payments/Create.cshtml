@model ComputerRepairService.Models.Entities.Payment

@{
    ViewData["Title"] = "Добавить платеж";
    Layout = "_Layout";

    var orderId = ViewBag.OrderId as int?;
    var serviceOrders = ViewBag.ServiceOrders as List<ComputerRepairService.Models.Entities.ServiceOrder>;
}

<div class="container mt-4">
    <h1 class="mb-4">Добавить платеж</h1>

    <div class="row">
        <div class="col-md-8">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Основная информация</h5>
                    </div>
                    <div class="card-body">
                        <div class="form-group mb-3">
                            <label asp-for="OrderId" class="form-label">Заказ</label>
                            <select asp-for="OrderId" class="form-select" required>
                                <option value="">-- Выберите заказ --</option>
                                @if (serviceOrders != null)
                                {
                                    foreach (var order in serviceOrders)
                                    {
                                        <option value="@order.OrderId" selected="@(orderId == order.OrderId)">
                                            Заказ #@order.OrderId - @order.Customer?.FirstName @order.Customer?.LastName
                                            (@order.TotalCost.ToString("C"))
                                        </option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="OrderId" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Amount" class="form-label">Сумма платежа</label>
                            <div class="input-group">
                                <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0" />
                                <span class="input-group-text">₽</span>
                            </div>
                            <span asp-validation-for="Amount" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">Детали оплаты</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="PaymentMethod" class="form-label">Метод оплаты</label>
                                    <select asp-for="PaymentMethod" class="form-select">
                                        <option value="">-- Выберите метод --</option>
                                        <option value="Cash">Наличные</option>
                                        <option value="Card">Банковская карта</option>
                                        <option value="Bank Transfer">Банковский перевод</option>
                                        <option value="Online">Онлайн-оплата</option>
                                    </select>
                                    <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="Status" class="form-label">Статус платежа</label>
                                    <select asp-for="Status" class="form-select">
                                        <option value="Pending">Ожидание</option>
                                        <option value="Completed" selected>Завершен</option>
                                        <option value="Failed">Ошибка</option>
                                        <option value="Refunded">Возврат</option>
                                    </select>
                                    <span asp-validation-for="Status" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="TransactionId" class="form-label">ID транзакции</label>
                            <input asp-for="TransactionId" class="form-control" placeholder="Например: tr_123456789" />
                            <small class="form-text text-muted">ID транзакции из платежной системы</small>
                            <span asp-validation-for="TransactionId" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0">Дополнительная информация</h5>
                    </div>
                    <div class="card-body">
                        <div class="form-group mb-3">
                            <label asp-for="Notes" class="form-label">Примечания</label>
                            <textarea asp-for="Notes" class="form-control" rows="3"
                                      placeholder="Дополнительная информация о платеже"></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save"></i> Сохранить платеж
                    </button>
                    <a asp-action="Index" class="btn btn-secondary ms-2">
                        <i class="fas fa-times"></i> Отмена
                    </a>
                </div>
            </form>
        </div>

        <div class="col-md-4">
            <div class="card bg-light">
                <div class="card-body">
                    <h5 class="card-title"><i class="fas fa-lightbulb"></i> Подсказки</h5>
                    <p class="card-text">
                        <strong>Статусы платежей:</strong>
                        <ul class="mt-2">
                            <li><span class="badge bg-warning">Ожидание</span> - платеж ожидает подтверждения</li>
                            <li><span class="badge bg-success">Завершен</span> - платеж успешно завершен</li>
                            <li><span class="badge bg-danger">Ошибка</span> - произошла ошибка при оплате</li>
                            <li><span class="badge bg-info">Возврат</span> - средства возвращены клиенту</li>
                        </ul>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Автозаполнение суммы при выборе заказа
        document.getElementById('OrderId').addEventListener('change', function() {
            const orderId = this.value;
            if (orderId) {
                // Здесь можно добавить AJAX запрос для получения суммы заказа
                // Пока оставляем пустым
            }
        });

        // Автогенерация ID транзакции при выборе метода оплаты
        document.getElementById('PaymentMethod').addEventListener('change', function() {
            const method = this.value;
            const transactionField = document.getElementById('TransactionId');

            if (method && !transactionField.value) {
                const prefix = method === 'Cash' ? 'CASH' :
                              method === 'Card' ? 'CARD' :
                              method === 'Bank Transfer' ? 'BANK' : 'ONLINE';
                const random = Math.floor(Math.random() * 1000000).toString().padStart(6, '0');
                transactionField.value = `${prefix}_${random}`;
            }
        });
    </script>
}