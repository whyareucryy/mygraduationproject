@model ComputerRepairService.Models.Entities.DeviceType

@{
    ViewData["Title"] = "Редактировать тип устройства";
    Layout = "_Layout";
}

<div class="container mt-4">
    <h1 class="mb-4">Редактировать тип устройства</h1>

    <div class="row">
        <div class="col-md-6">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="DeviceTypeId" />

                <div class="form-group mb-3">
                    <label asp-for="TypeName" class="form-label"></label>
                    <input asp-for="TypeName" class="form-control" />
                    <span asp-validation-for="TypeName" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save"></i> Сохранить изменения
                    </button>
                    <a asp-action="Index" class="btn btn-secondary ms-2">
                        <i class="fas fa-times"></i> Отмена
                    </a>
                </div>
            </form>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="fas fa-history"></i> История</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-5">ID типа:</dt>
                        <dd class="col-sm-7">@Model.DeviceTypeId</dd>

                        <dt class="col-sm-5">Текущее название:</dt>
                        <dd class="col-sm-7">@Model.TypeName</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}