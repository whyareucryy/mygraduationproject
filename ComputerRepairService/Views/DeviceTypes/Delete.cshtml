@model ComputerRepairService.Models.Entities.DeviceType

@{
    ViewData["Title"] = "Удалить тип устройства";
    Layout = "_Layout";
}

<div class="container mt-4">
    <h1 class="mb-4">Удалить тип устройства</h1>

    <div class="alert alert-danger">
        <h4><i class="fas fa-exclamation-triangle"></i> Внимание!</h4>
        <p>Вы уверены, что хотите удалить этот тип устройства? Это действие нельзя отменить.</p>
    </div>

    <div class="card">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">Подтверждение удаления</h4>
        </div>
        <div class="card-body">
            <h5>Информация о типе устройства:</h5>
            <dl class="row">
                <dt class="col-sm-3">ID:</dt>
                <dd class="col-sm-9">@Model.DeviceTypeId</dd>

                <dt class="col-sm-3">Название типа:</dt>
                <dd class="col-sm-9">@Model.TypeName</dd>

                <dt class="col-sm-3">Описание:</dt>
                <dd class="col-sm-9">@(Model.Description ?? "Нет описания")</dd>

                <dt class="col-sm-3">Связанных заказов:</dt>
                <dd class="col-sm-9">@(ViewBag.RelatedOrdersCount ?? 0)</dd>
            </dl>

            @if ((int)(ViewBag.RelatedOrdersCount ?? 0) > 0)
            {
                <div class="alert alert-danger">
                    <strong>Удаление заблокировано:</strong> пока есть заказы с этим типом устройства, удалить запись нельзя.
                </div>
            }
            else
            {
                <div class="alert alert-warning">
                    <strong>Внимание:</strong> это действие нельзя отменить.
                </div>
            }
        </div>
        <div class="card-footer">
            <form asp-action="Delete">
                <input type="hidden" asp-for="DeviceTypeId" />
                <button type="submit" class="btn btn-danger" @(((int)(ViewBag.RelatedOrdersCount ?? 0) > 0) ? "disabled" : null)>
                    <i class="fas fa-trash"></i> Удалить
                </button>
                <a asp-action="Index" class="btn btn-secondary ms-2">
                    <i class="fas fa-times"></i> Отмена
                </a>
            </form>
        </div>
    </div>
</div>