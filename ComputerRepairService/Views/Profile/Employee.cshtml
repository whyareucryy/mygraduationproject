@model ComputerRepairService.Controllers.EmployeeDashboardViewModel
@{
    ViewData["Title"] = "Панель сотрудника";
}

<div class="container-fluid mt-4">
    <!-- Заголовок -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1><i class="fas fa-user-cog"></i> Панель сотрудника</h1>
            <p class="text-muted mb-0">
                Добро пожаловать, @Model.User.FirstName @Model.User.LastName!
                @if (Model.Technician != null)
                {
                    <span class="badge bg-info ms-2">@Model.Technician.Specialization</span>
                }
            </p>
        </div>
        <div class="btn-group">
            <a asp-action="AccountInfo" class="btn btn-outline-info">
                <i class="fas fa-user-cog"></i> Настройки
            </a>
            <a asp-controller="ServiceOrders" asp-action="MyAssignedOrders" class="btn btn-primary">
                <i class="fas fa-tasks"></i> Мои задачи
            </a>
        </div>
    </div>

    <!-- Статистика сотрудника -->
    <div class="row mb-4">
        <div class="col-md-3 mb-4">
            <div class="card bg-primary text-white">
                <div class="card-body text-center py-4">
                    <h1 class="display-5 mb-2">@Model.AssignedOrders</h1>
                    <p class="mb-0">Всего задач</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card bg-warning text-dark">
                <div class="card-body text-center py-4">
                    <h1 class="display-5 mb-2">@Model.ActiveAssignedOrders</h1>
                    <p class="mb-0">Активных задач</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card bg-success text-white">
                <div class="card-body text-center py-4">
                    <h1 class="display-5 mb-2">@Model.CompletedOrdersThisMonth</h1>
                    <p class="mb-0">Завершено в этом месяце</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card bg-info text-white">
                <div class="card-body text-center py-4">
                    <h1 class="display-5 mb-2">@Model.TotalHoursWorked</h1>
                    <p class="mb-0">Всего часов работы</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Активные задачи -->
    <div class="row">
        <div class="col-lg-8 mb-4">
            <div class="card shadow">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="fas fa-tasks me-2"></i> Мои активные задачи</h5>
                </div>
                <div class="card-body">
                    @if (Model.MyActiveOrders.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Клиент</th>
                                        <th>Устройство</th>
                                        <th>Проблема</th>
                                        <th>Статус</th>
                                        <th>Приоритет</th>
                                        <th>Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model.MyActiveOrders)
                                    {
                                        <tr>
                                            <td><strong>#@order.OrderId</strong></td>
                                            <td>@order.Customer?.FirstName @order.Customer?.LastName</td>
                                            <td>
                                                @if (order.DeviceType != null)
                                                {
                                                    <span class="badge bg-secondary">@order.DeviceType.TypeName</span>
                                                }
                                                <br>
                                                <small>@order.DeviceBrand @order.DeviceModel</small>
                                            </td>
                                            <td>
                                                <div class="text-truncate" style="max-width: 200px;">
                                                    @order.ProblemDescription
                                                </div>
                                            </td>
                                            <td>
                                                <partial name="_OrderStatusBadge" model="order.OrderStatus?.StatusName" />
                                            </td>
                                            <td>
                                                @switch (order.Priority)
                                                {
                                                    case 1:
                                                        <span class="badge bg-success">Низкий</span>
                                                        ; break;
                                                    case 2:

                                                        <span class="badge bg-warning text-dark">Средний</span>
                                                        ; break;
                                                    case 3:

                                                        <span class="badge bg-danger">Высокий</span>
                                                        ; break;
                                                    default:

                                                        <span class="badge bg-secondary">Не указан</span>
                                                        ; break;
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group btn-group-sm">
                                                    <a asp-controller="ServiceOrders" asp-action="Details" asp-route-id="@order.OrderId"
                                                       class="btn btn-info" title="Подробнее">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <a asp-controller="ServiceOrders" asp-action="ChangeStatus" asp-route-id="@order.OrderId"
                                                       class="btn btn-warning" title="Изменить статус">
                                                        <i class="fas fa-sync-alt"></i>
                                                    </a>
                                                    <a asp-controller="ServiceOrders" asp-action="Edit" asp-route-id="@order.OrderId"
                                                       class="btn btn-primary" title="Редактировать">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-clipboard-check fa-3x text-success mb-3"></i>
                            <h4>Нет активных задач</h4>
                            <p class="text-muted">Все задачи выполнены!</p>
                            <a asp-controller="ServiceOrders" asp-action="Index" class="btn btn-primary">
                                <i class="fas fa-list"></i> Посмотреть все заказы
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Боковая панель -->
        <div class="col-lg-4">
            <!-- Профиль техника -->
            <div class="card shadow mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="fas fa-id-card me-2"></i> Мой профиль</h5>
                </div>
                <div class="card-body">
                    @if (Model.Technician != null)
                    {
                        <div class="text-center mb-4">
                            <div class="avatar bg-primary text-white rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3"
                                 style="width: 80px; height: 80px;">
                                <i class="fas fa-user-cog fa-2x"></i>
                            </div>
                            <h4>@Model.Technician.FirstName @Model.Technician.LastName</h4>
                            <p class="text-muted mb-2">@Model.Technician.Specialization</p>
                            <p class="mb-0">
                                <i class="fas fa-envelope me-1"></i> @Model.Technician.Email<br>
                                <i class="fas fa-phone me-1"></i> @Model.Technician.Phone
                            </p>
                        </div>

                        <div class="list-group list-group-flush">
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <span><i class="fas fa-calendar-alt me-2"></i> Дата приема</span>
                                <span class="badge bg-info">@Model.Technician.HireDate.ToString("dd.MM.yyyy")</span>
                            </div>
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <span><i class="fas fa-money-bill-wave me-2"></i> Часовая ставка</span>
                                <span class="badge bg-success">@(Model.Technician.HourlyRate.HasValue? Model.Technician.HourlyRate.Value.ToString("C") : "Не указана")</span>
                            </div>
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <span><i class="fas fa-user-check me-2"></i> Статус</span>
                                <span class="badge bg-@(Model.Technician.IsActive ? "success" : "danger")">
                                    @(Model.Technician.IsActive ? "Активен" : "Неактивен")
                                </span>
                            </div>
                        </div>

                        <a asp-action="EditProfile" class="btn btn-outline-primary w-100 mt-3">
                            <i class="fas fa-edit"></i> Редактировать профиль
                        </a>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-triangle"></i> Профиль мастера не найден
                        </div>
                    }
                </div>
            </div>

            <!-- Последние выполненные услуги -->
            @if (Model.RecentServices.Any())
            {
                <div class="card shadow">
                    <div class="card-header bg-light">
                        <h5 class="mb-0"><i class="fas fa-history me-2"></i> Последние работы</h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group list-group-flush">
                            @foreach (var service in Model.RecentServices)
                            {
                                <div class="list-group-item">
                                    <div class="d-flex w-100 justify-content-between">
                                        <h6 class="mb-1">@service.Service?.ServiceName</h6>
                                        <small>@service.ServiceDate.ToString("dd.MM")</small>
                                    </div>
                                    <p class="mb-1 small">Заказ #@service.OrderId</p>
                                    <small class="text-success">@service.TotalPrice.ToString("C")</small>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>