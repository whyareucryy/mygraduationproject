@model ComputerRepairService.Controllers.ClientDashboardViewModel
@{
    ViewData["Title"] = "Личный кабинет";
}

<div class="container mt-4">
    <!-- Заголовок -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1><i class="fas fa-user"></i> Личный кабинет</h1>
            <p class="text-muted mb-0">Добро пожаловать, @Model.User.FirstName @Model.User.LastName!</p>
        </div>
        <div class="btn-group">
            <a asp-action="EditProfile" class="btn btn-outline-primary">
                <i class="fas fa-edit"></i> Редактировать профиль
            </a>
            <a asp-action="ChangePassword" class="btn btn-outline-info">
                <i class="fas fa-key"></i> Сменить пароль
            </a>
        </div>
    </div>

    <!-- Статистика клиента -->
    <div class="row mb-4">
        <div class="col-md-3 mb-4">
            <div class="card bg-primary text-white">
                <div class="card-body text-center py-4">
                    <h1 class="display-5 mb-2">@Model.TotalOrders</h1>
                    <p class="mb-0">Всего заказов</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card bg-warning text-dark">
                <div class="card-body text-center py-4">
                    <h1 class="display-5 mb-2">@Model.ActiveOrders</h1>
                    <p class="mb-0">Активных заказов</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card bg-success text-white">
                <div class="card-body text-center py-4">
                    <h1 class="display-5 mb-2">@Model.CompletedOrders</h1>
                    <p class="mb-0">Завершенных</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card bg-info text-white">
                <div class="card-body text-center py-4">
                    <h1 class="display-5 mb-2">@Model.TotalSpent.ToString("C")</h1>
                    <p class="mb-0">Всего потрачено</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Профиль клиента -->
        <div class="col-lg-4 mb-4">
            <div class="card shadow">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="fas fa-id-card me-2"></i> Мой профиль</h5>
                </div>
                <div class="card-body">
                    @if (Model.Customer != null)
                    {
                        <div class="text-center mb-4">
                            <div class="avatar bg-primary text-white rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3"
                                 style="width: 80px; height: 80px;">
                                <i class="fas fa-user fa-2x"></i>
                            </div>
                            <h4>@Model.Customer.FirstName @Model.Customer.LastName</h4>
                            <p class="text-muted mb-3">Клиент сервисного центра</p>
                        </div>

                        <div class="list-group list-group-flush">
                            <div class="list-group-item">
                                <div class="d-flex align-items-center">
                                    <i class="fas fa-envelope text-primary me-3" style="width: 20px;"></i>
                                    <div>
                                        <small class="text-muted">Email</small>
                                        <div>@Model.Customer.Email</div>
                                    </div>
                                </div>
                            </div>
                            <div class="list-group-item">
                                <div class="d-flex align-items-center">
                                    <i class="fas fa-phone text-primary me-3" style="width: 20px;"></i>
                                    <div>
                                        <small class="text-muted">Телефон</small>
                                        <div>@Model.Customer.Phone</div>
                                    </div>
                                </div>
                            </div>
                            <div class="list-group-item">
                                <div class="d-flex align-items-center">
                                    <i class="fas fa-map-marker-alt text-primary me-3" style="width: 20px;"></i>
                                    <div>
                                        <small class="text-muted">Адрес</small>
                                        <div>@Model.Customer.Address</div>
                                    </div>
                                </div>
                            </div>
                            <div class="list-group-item">
                                <div class="d-flex align-items-center">
                                    <i class="fas fa-calendar-alt text-primary me-3" style="width: 20px;"></i>
                                    <div>
                                        <small class="text-muted">Дата регистрации</small>
                                        <div>@Model.Customer.RegistrationDate.ToString("dd.MM.yyyy")</div>
                                    </div>
                                </div>
                            </div>
                            <div class="list-group-item">
                                <div class="d-flex align-items-center">
                                    <i class="fas fa-user-check text-primary me-3" style="width: 20px;"></i>
                                    <div>
                                        <small class="text-muted">Статус</small>
                                        <div>
                                            <span class="badge bg-@(Model.Customer.IsActive ? "success" : "danger")">
                                                @(Model.Customer.IsActive ? "Активен" : "Неактивен")
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-3">
                            <a asp-action="EditProfile" class="btn btn-primary">
                                <i class="fas fa-edit"></i> Редактировать профиль
                            </a>
                            <a asp-controller="ServiceOrders" asp-action="Create" class="btn btn-success">
                                <i class="fas fa-plus-circle"></i> Создать новый заказ
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-triangle"></i> Профиль клиента не найден
                        </div>
                        <a asp-controller="Customers" asp-action="Create" class="btn btn-primary w-100">
                            <i class="fas fa-user-plus"></i> Создать профиль клиента
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- Последние заказы -->
        <div class="col-lg-8">
            <div class="card shadow mb-4">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-clipboard-list me-2"></i> Последние заказы</h5>
                    <a asp-controller="ServiceOrders" asp-action="MyOrders" class="btn btn-sm btn-primary">
                        Все заказы
                    </a>
                </div>
                <div class="card-body">
                    @if (Model.RecentOrders.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Устройство</th>
                                        <th>Проблема</th>
                                        <th>Статус</th>
                                        <th>Дата</th>
                                        <th>Стоимость</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model.RecentOrders)
                                    {
                                        <tr>
                                            <td><strong>#@order.OrderId</strong></td>
                                            <td>
                                                @if (order.DeviceType != null)
                                                {
                                                    <span class="badge bg-secondary">@order.DeviceType.TypeName</span>
                                                }
                                                <br>
                                                <small>@order.DeviceBrand @order.DeviceModel</small>
                                            </td>
                                            <td>
                                                <div class="text-truncate" style="max-width: 200px;">
                                                    @order.ProblemDescription
                                                </div>
                                            </td>
                                            <td>
                                                <partial name="_OrderStatusBadge" model="order.OrderStatus?.StatusName" />
                                            </td>
                                            <td>@order.CreatedDate.ToString("dd.MM.yyyy")</td>
                                            <td>
                                                @if (order.TotalCost > 0)
                                                {
                                                    <span class="badge bg-success">@order.TotalCost.ToString("C")</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Не рассчитана</span>
                                                }
                                            </td>
                                            <td>
                                                <a asp-controller="ServiceOrders" asp-action="Details" asp-route-id="@order.OrderId"
                                                   class="btn btn-sm btn-info">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                            <h4>У вас пока нет заказов</h4>
                            <p class="text-muted mb-3">Создайте свой первый заказ на ремонт</p>
                            <a asp-controller="ServiceOrders" asp-action="Create" class="btn btn-success btn-lg">
                                <i class="fas fa-plus"></i> Создать заказ
                            </a>
                        </div>
                    }
                </div>
            </div>

            <!-- Последние платежи -->
            @if (Model.RecentPayments.Any())
            {
                <div class="card shadow">
                    <div class="card-header bg-light">
                        <h5 class="mb-0"><i class="fas fa-credit-card me-2"></i> Последние платежи</h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group">
                            @foreach (var payment in Model.RecentPayments)
                            {
                                <div class="list-group-item list-group-item-action">
                                    <div class="d-flex w-100 justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-1">Платеж по заказу #@payment.OrderId</h6>
                                            <small class="text-muted">
                                                @payment.PaymentDate.ToString("dd.MM.yyyy HH:mm") •
                                                Метод: @payment.PaymentMethod
                                            </small>
                                        </div>
                                        <div class="text-end">
                                            <h5 class="mb-0 text-@(payment.Status == "Completed" ? "success" : "warning")">
                                                @payment.Amount.ToString("C")
                                            </h5>
                                            <small class="text-muted">Статус: @payment.Status</small>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>