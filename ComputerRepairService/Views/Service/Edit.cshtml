@model ComputerRepairService.Models.Entities.Service

@{
    ViewData["Title"] = "Редактировать услугу";
    Layout = "_Layout";
}

<div class="container mt-4">
    <h1 class="mb-4">Редактировать услугу</h1>

    <div class="row">
        <div class="col-md-8">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="ServiceId" />

                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Основная информация</h5>
                    </div>
                    <div class="card-body">
                        <div class="form-group mb-3">
                            <label asp-for="ServiceName" class="form-label"></label>
                            <input asp-for="ServiceName" class="form-control" />
                            <span asp-validation-for="ServiceName" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">Цена и время</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="BasePrice" class="form-label"></label>
                                    <div class="input-group">
                                        <input asp-for="BasePrice" class="form-control" />
                                        <span class="input-group-text">₽</span>
                                    </div>
                                    <span asp-validation-for="BasePrice" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="EstimatedDuration" class="form-label"></label>
                                    <div class="input-group">
                                        <input asp-for="EstimatedDuration" class="form-control" />
                                        <span class="input-group-text">мин</span>
                                    </div>
                                    <span asp-validation-for="EstimatedDuration" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save"></i> Сохранить изменения
                    </button>
                    <a asp-action="Details" asp-route-id="@Model.ServiceId" class="btn btn-secondary ms-2">
                        <i class="fas fa-times"></i> Отмена
                    </a>
                </div>
            </form>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="fas fa-info-circle"></i> Информация</h5>
                </div>
                <div class="card-body">
                    <dl>
                        <dt>ID услуги:</dt>
                        <dd>@Model.ServiceId</dd>

                        <dt>Текущее название:</dt>
                        <dd>@Model.ServiceName</dd>

                        <dt>Статус:</dt>
                        <dd>
                            @if (Model.IsActive)
                            {
                                <span class="badge bg-success">Активна</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Неактивна</span>
                            }
                        </dd>
                    </dl>

                    @if (Model.OrderServices != null && Model.OrderServices.Any())
                    {
                        <div class="alert alert-info mt-3">
                            <i class="fas fa-exclamation-circle"></i>
                            <strong>Внимание:</strong> Эта услуга используется в @Model.OrderServices.Count заказах.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}