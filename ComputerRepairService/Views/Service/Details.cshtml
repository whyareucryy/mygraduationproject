@model ComputerRepairService.Models.Entities.Service

@{
    ViewData["Title"] = "Подробности об услуге";
    Layout = "_Layout";
}

<div class="container mt-4">
    <h1 class="mb-4">Подробности об услуге</h1>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Информация об услуге</h4>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">ID услуги:</dt>
                        <dd class="col-sm-8">@Model.ServiceId</dd>

                        <dt class="col-sm-4">Название услуги:</dt>
                        <dd class="col-sm-8">@Model.ServiceName</dd>

                        <dt class="col-sm-4">Описание:</dt>
                        <dd class="col-sm-8">@(Model.Description ?? "Нет описания")</dd>

                        <dt class="col-sm-4">Базовая цена:</dt>
                        <dd class="col-sm-8">@Model.BasePrice.ToString("C")</dd>

                        <dt class="col-sm-4">Примерная длительность:</dt>
                        <dd class="col-sm-8">
                            @if (Model.EstimatedDuration.HasValue)
                            {
                                var hours = Model.EstimatedDuration.Value / 60;
                                var minutes = Model.EstimatedDuration.Value % 60;

                                if (hours > 0)
                                {
                                    @($"{hours} ч {minutes} мин")
                                }
                                else
                                {
                                    @($"{minutes} мин")
                                }
                            }
                            else
                            {
                                <span class="text-muted">Не указана</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Статус:</dt>
                        <dd class="col-sm-8">
                            @if (Model.IsActive)
                            {
                                <span class="badge bg-success">Активна</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Неактивна</span>
                            }
                        </dd>
                    </dl>
                </div>
                <div class="card-footer">
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@Model.ServiceId" class="btn btn-warning">
                            <i class="fas fa-edit"></i> Редактировать
                        </a>
                    }
                    <a asp-action="Index" class="btn btn-secondary ms-2">
                        <i class="fas fa-arrow-left"></i> Назад к списку
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            @if (Model.OrderServices != null && Model.OrderServices.Any())
            {
                <div class="card">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0"><i class="fas fa-list"></i> Использование</h5>
                    </div>
                    <div class="card-body">
                        <p class="card-text">
                            Эта услуга использована в <strong>@Model.OrderServices.Count</strong> заказах.
                        </p>
                        <a asp-controller="OrderServices" asp-action="Index" class="btn btn-sm btn-outline-info">
                            Посмотреть все заказы с этой услугой
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>