@model ComputerRepairService.Models.Entities.Service

@{
    ViewData["Title"] = "Добавить новую услугу";
    Layout = "_Layout";
}

<div class="container mt-4">
    <h1 class="mb-4">Добавить новую услугу</h1>

    <div class="row">
        <div class="col-md-8">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Основная информация</h5>
                    </div>
                    <div class="card-body">
                        <div class="form-group mb-3">
                            <label asp-for="ServiceName" class="form-label"></label>
                            <input asp-for="ServiceName" class="form-control" placeholder="Введите название услуги" />
                            <span asp-validation-for="ServiceName" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" class="form-control" rows="4"
                                      placeholder="Опишите услугу подробно"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">Цена и время</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="BasePrice" class="form-label"></label>
                                    <div class="input-group">
                                        <input asp-for="BasePrice" class="form-control" placeholder="0.00" />
                                        <span class="input-group-text">₽</span>
                                    </div>
                                    <span asp-validation-for="BasePrice" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="EstimatedDuration" class="form-label"></label>
                                    <div class="input-group">
                                        <input asp-for="EstimatedDuration" class="form-control" placeholder="В минутах" />
                                        <span class="input-group-text">мин</span>
                                    </div>
                                    <span asp-validation-for="EstimatedDuration" class="text-danger"></span>
                                    <small class="form-text text-muted">Оставьте пустым, если время не определено</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save"></i> Сохранить услугу
                    </button>
                    <a asp-action="Index" class="btn btn-secondary ms-2">
                        <i class="fas fa-times"></i> Отмена
                    </a>
                </div>
            </form>
        </div>

        <div class="col-md-4">
            <div class="card bg-light">
                <div class="card-body">
                    <h5 class="card-title"><i class="fas fa-lightbulb"></i> Примеры услуг</h5>
                    <p class="card-text">
                        <strong>Типичные услуги компьютерного сервиса:</strong>
                        <ul class="mt-2">
                            <li>Диагностика компьютера</li>
                            <li>Установка/переустановка ОС</li>
                            <li>Очистка от пыли и замена термопасты</li>
                            <li>Замена комплектующих</li>
                            <li>Восстановление данных</li>
                            <li>Удаление вирусов</li>
                            <li>Настройка сети и Wi-Fi</li>
                        </ul>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Форматирование ввода цены
        document.getElementById('BasePrice').addEventListener('input', function(e) {
            let value = e.target.value.replace(/[^\d.]/g, '');
            let parts = value.split('.');
            if (parts.length > 2) {
                value = parts[0] + '.' + parts.slice(1).join('');
            }
            e.target.value = value;
        });
    </script>
}