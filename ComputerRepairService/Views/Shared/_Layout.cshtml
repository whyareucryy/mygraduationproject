@using Microsoft.AspNetCore.Identity
@using ComputerRepairService.Models.Entities
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    var controllerNames = new Dictionary<string, string>
    {
        { "Home", "Главная" },
        { "Dashboard", "Панель управления" },
        { "Profile", "Личный профиль" },
        { "ServiceOrders", "Заказы" },
        { "Customers", "Клиенты" },
        { "Technicians", "Мастера" },
        { "Inventory", "Склад" },
        { "Payments", "Платежи" },
        { "DeviceTypes", "Типы устройств" },
        { "Account", "Аккаунт" }
    };

    var actionNames = new Dictionary<string, string>
    {
        { "Index", "Список" },
        { "Create", "Добавление" },
        { "Edit", "Редактирование" },
        { "Details", "Подробности" },
        { "Delete", "Удаление" },
        { "ClientRequests", "Заявки клиентов" },
        { "MyAssignedOrders", "Мои задачи" },
        { "MyOrders", "Мои заказы" },
        { "UnpaidOrders", "Ожидают оплаты" },
        { "AccountInfo", "Настройки" },
        { "Login", "Вход" },
        { "Register", "Регистрация" },
        { "IssueOrder", "Выдача устройства" }
    };

    var controllerName = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var actionName = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    var displayController = controllerNames.ContainsKey(controllerName) ? controllerNames[controllerName] : controllerName;
    var displayAction = actionNames.ContainsKey(actionName) ? actionNames[actionName] : actionName;
}

<!DOCTYPE html>
<html lang="ru" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Компьютерный сервис</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css">

    <!-- Select2 -->
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

    <!-- Toastr -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="~/favicon.ico">

    @await RenderSectionAsync("Styles", required: false)

    
</head>
<body>
    <!-- Верхняя панель навигации -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white fixed-top shadow-sm">
        <div class="container-fluid">
            <!-- Кнопка меню -->
            <button class="btn btn-primary me-3" id="sidebarToggle">
                <i class="fas fa-bars"></i>
            </button>

            <!-- Бренд/логотип -->
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <i class="fas fa-tools me-2"></i> Компьютерный сервис
            </a>

            <!-- Кнопка переключения темы -->
            <button class="btn btn-outline-secondary me-3" id="themeToggle">
                <i class="fas fa-moon"></i>
            </button>

            <!-- Основное меню -->
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <!-- Ссылки были удалены по просьбе пользователя, так как они дублируются в боковой панели -->
                </ul>

                <!-- Правая часть: уведомления и пользователь -->
                <ul class="navbar-nav align-items-center">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <!-- Уведомления -->
                        <li class="nav-item dropdown me-3">
                            <a class="nav-link position-relative" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-bell"></i>
                            </a>
                            <div class="dropdown-menu dropdown-menu-end" style="width: 320px; max-height: 400px; overflow-y: auto;">
                                <h6 class="dropdown-header">Уведомления</h6>
                                @await Component.InvokeAsync("PaymentNotifications")
                            </div>
                        </li>

                        <!-- Пользователь -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown">
                                <div class="user-avatar me-2">
                                    @if (User.Identity.Name != null)
                                    {
                                        @User.Identity.Name.Substring(0, 1).ToUpper()
                                    }
                                </div>
                                <div class="d-none d-md-block">
                                    <div class="fw-bold">@User.Identity.Name</div>
                                    <small class="text-light">
                                        @{
                                            var user = await UserManager.GetUserAsync(User);
                                            if (user != null)
                                            {
                                                var roles = await UserManager.GetRolesAsync(user);
                                                if (roles.Contains("Admin"))
                                                {
                                                    <span class="badge bg-danger badge-role">Админ</span>
                                                }
                                                else if (roles.Contains("Employee"))
                                                {
                                                    <span class="badge bg-warning text-dark badge-role">Сотрудник</span>
                                                }
                                                else if (roles.Contains("Client"))
                                                {
                                                    <span class="badge bg-info badge-role">Клиент</span>
                                                }
                                            }
                                        }
                                    </small>
                                </div>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-3" style="min-width: 260px; padding: 0.5rem 0;">
                                <li class="px-3 py-3 border-bottom mb-2 bg-light rounded-top-3">
                                    <div class="d-flex align-items-center">
                                        <div class="user-avatar bg-primary text-white rounded-circle d-flex justify-content-center align-items-center me-3 shadow-sm" style="width: 48px; height: 48px; font-size: 1.5rem; flex-shrink: 0;">
                                            @if (User.Identity.Name != null)
                                            {
                                                @User.Identity.Name.Substring(0, 1).ToUpper()
                                            }
                                        </div>
                                        <div class="overflow-hidden">
                                            <div class="fw-bold text-truncate" style="font-size: 1.05rem;">@User.Identity.Name</div>
                                            <div class="text-muted small">
                                                @if (User.IsInRole("Admin")) { <span class="text-danger fw-semibold"><i class="fas fa-crown me-1"></i>Администратор</span> }
                                                else if (User.IsInRole("Employee")) { <span class="text-warning text-dark fw-semibold"><i class="fas fa-briefcase me-1"></i>Сотрудник</span> }
                                                else { <span class="text-info text-dark fw-semibold"><i class="fas fa-user-tie me-1"></i>Клиент</span> }
                                            </div>
                                        </div>
                                    </div>
                                </li>

                                <li>
                                    <a class="dropdown-item py-2 d-flex align-items-center" asp-controller="Home" asp-action="Index">
                                        <div class="bg-success bg-opacity-10 text-success rounded p-2 me-3 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;"><i class="fas fa-home"></i></div>
                                        <span class="fw-medium">Главная страница</span>
                                    </a>
                                </li>

                                @if (User.IsInRole("Admin"))
                                {
                                    <li>
                                        <a class="dropdown-item py-2 d-flex align-items-center" asp-controller="Dashboard" asp-action="Index">
                                            <div class="bg-danger bg-opacity-10 text-danger rounded p-2 me-3 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;"><i class="fas fa-chart-line"></i></div>
                                            <span class="fw-medium">Панель управления</span>
                                        </a>
                                    </li>
                                }
                                else if (User.IsInRole("Employee"))
                                {
                                    <li>
                                        <a class="dropdown-item py-2 d-flex align-items-center" asp-controller="ServiceOrders" asp-action="MyAssignedOrders">
                                            <div class="bg-warning bg-opacity-10 text-warning rounded p-2 me-3 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;"><i class="fas fa-tasks"></i></div>
                                            <span class="fw-medium">Мои задачи</span>
                                        </a>
                                    </li>
                                }
                                else if (User.IsInRole("Client"))
                                {
                                    <li>
                                        <a class="dropdown-item py-2 d-flex align-items-center" asp-controller="ServiceOrders" asp-action="MyOrders">
                                            <div class="bg-info bg-opacity-10 text-info rounded p-2 me-3 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;"><i class="fas fa-box-open"></i></div>
                                            <span class="fw-medium">Мои заказы</span>
                                        </a>
                                    </li>
                                }

                                <li><hr class="dropdown-divider my-2"></li>
                                <li><h6 class="dropdown-header text-uppercase text-muted small fw-bold" style="letter-spacing: 0.5px;">Настройки</h6></li>
                                
                                <li>
                                    <a class="dropdown-item py-2 d-flex align-items-center" asp-controller="Profile" asp-action="AccountInfo">
                                        <div class="bg-secondary bg-opacity-10 text-secondary rounded p-2 me-3 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;"><i class="fas fa-user-circle"></i></div>
                                        <span>Личный профиль</span>
                                    </a>
                                </li>

                                <li><hr class="dropdown-divider my-2"></li>
                                <li class="px-2">
                                    <form class="form-inline m-0" asp-area="Identity" asp-page="/Account/Logout" method="post">
                                        <button type="submit" class="dropdown-item py-2 d-flex align-items-center text-danger rounded">
                                            <i class="fas fa-sign-out-alt me-3" style="width: 16px; text-align: center;"></i>
                                            <span class="fw-medium">Выйти из аккаунта</span>
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">
                                <i class="fas fa-sign-in-alt"></i> Вход
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Identity" asp-page="/Account/Register">
                                <i class="fas fa-user-plus"></i> Регистрация
                            </a>
                        </li>
                    }
                </ul>
            </div>

            <!-- Кнопка мобильного меню -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
        </div>
    </nav>

    <!-- Боковое меню -->
    <div class="sidebar" id="sidebar">
        <ul class="sidebar-menu">
            <li class="menu-header mb-3 px-3">
                <small class="text-uppercase text-muted">Основное меню</small>
            </li>

            <li>
                <a asp-controller="Home" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                    <i class="fas fa-home"></i> Главная
                </a>
            </li>

            @if (SignInManager.IsSignedIn(User))
            {
                @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                {
                    <li>
                        <a asp-controller="Dashboard" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                            <i class="fas fa-tachometer-alt"></i> Панель управления
                        </a>
                    </li>
                }

                <li>
                    <a asp-controller="Profile" asp-action="AccountInfo" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Profile" && ViewContext.RouteData.Values["action"]?.ToString() == "AccountInfo" ? "active" : "")">
                        <i class="fas fa-user"></i> Личный профиль
                    </a>
                </li>

                <!-- Заказы -->
                <li>
                    <a href="#" class="has-submenu @(ViewContext.RouteData.Values["controller"]?.ToString() == "ServiceOrders" ? "active" : "")">
                        <i class="fas fa-clipboard-list"></i> Заказы
                        <i class="fas fa-chevron-right ms-auto"></i>
                    </a>
                    <ul class="sidebar-submenu @(ViewContext.RouteData.Values["controller"]?.ToString() == "ServiceOrders" ? "show" : "")">
                        @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                        {
                            <li><a asp-controller="ServiceOrders" asp-action="Index"><i class="fas fa-list"></i> Все заказы</a></li>
                            <li><a asp-controller="ServiceOrders" asp-action="ClientRequests"><i class="fas fa-inbox"></i> Заявки клиентов</a></li>
                            <li><a asp-controller="ServiceOrders" asp-action="Create"><i class="fas fa-plus-circle"></i> Создать заказ</a></li>
                        }

                        @if (User.IsInRole("Employee"))
                        {
                            <li><a asp-controller="ServiceOrders" asp-action="MyAssignedOrders"><i class="fas fa-tasks"></i> Мои задачи</a></li>
                        }

                        @if (User.IsInRole("Client"))
                        {
                            <li><a asp-controller="ServiceOrders" asp-action="MyOrders"><i class="fas fa-box"></i> Мои заказы</a></li>
                            <li><a asp-controller="ServiceOrders" asp-action="UnpaidOrders"><i class="fas fa-credit-card"></i> К оплате</a></li>
                            <li><a asp-controller="ServiceOrders" asp-action="Create"><i class="fas fa-plus-circle"></i> Новый заказ</a></li>
                        }
                    </ul>
                </li>

                <!-- Управление (только для админов) -->
                @if (User.IsInRole("Admin"))
                {
                    <li>
                        <a href="#" class="has-submenu @(ViewContext.RouteData.Values["controller"]?.ToString() == "Customers" ||
                                                                                             ViewContext.RouteData.Values["controller"]?.ToString() == "Technicians" ||
                                                                                             ViewContext.RouteData.Values["controller"]?.ToString() == "Inventory" ||
                                                                                             ViewContext.RouteData.Values["controller"]?.ToString() == "DeviceTypes" ? "active" : "")">
                            <i class="fas fa-cogs"></i> Управление
                            <i class="fas fa-chevron-right ms-auto"></i>
                        </a>
                        <ul class="sidebar-submenu @(ViewContext.RouteData.Values["controller"]?.ToString() == "Customers" ||
                                                                                 ViewContext.RouteData.Values["controller"]?.ToString() == "Technicians" ||
                                                                                 ViewContext.RouteData.Values["controller"]?.ToString() == "Inventory" ||
                                                                                 ViewContext.RouteData.Values["controller"]?.ToString() == "DeviceTypes" ? "show" : "")">
                            <li><a asp-controller="Customers" asp-action="Index"><i class="fas fa-users"></i> Клиенты</a></li>
                            <li><a asp-controller="Technicians" asp-action="Index"><i class="fas fa-user-cog"></i> Мастера</a></li>
                            <li><a asp-controller="Inventory" asp-action="Index"><i class="fas fa-boxes"></i> Склад</a></li>
                            <li><a asp-controller="DeviceTypes" asp-action="Index"><i class="fas fa-laptop"></i> Типы устройств</a></li>
                        </ul>
                    </li>

                    <li>
                        <a asp-controller="Payments" asp-action="Index"
                           class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Payments" ? "active" : "")">
                            <i class="fas fa-credit-card"></i> Платежи
                        </a>
                    </li>
                }

                <!-- Для сотрудников -->
                @if (User.IsInRole("Employee"))
                {
                    <li>
                        <a asp-controller="Inventory" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Inventory" ? "active" : "")">
                            <i class="fas fa-boxes"></i> Склад
                        </a>
                    </li>
                    <li>
                        <a href="#" class="has-submenu @(ViewContext.RouteData.Values["controller"]?.ToString() == "Payments" ||
                                                                                             ViewContext.RouteData.Values["controller"]?.ToString() == "DeviceTypes" ? "active" : "")">
                            <i class="fas fa-hand-holding-usd"></i> Оплата и справочники
                            <i class="fas fa-chevron-right ms-auto"></i>
                        </a>
                        <ul class="sidebar-submenu @(ViewContext.RouteData.Values["controller"]?.ToString() == "Payments" ||
                                                                                 ViewContext.RouteData.Values["controller"]?.ToString() == "DeviceTypes" ? "show" : "")">
                            <li><a asp-controller="Payments" asp-action="Index"><i class="fas fa-credit-card"></i> Платежи</a></li>
                            <li><a asp-controller="DeviceTypes" asp-action="Index"><i class="fas fa-laptop"></i> Типы устройств</a></li>
                            <li><a asp-controller="DeviceTypes" asp-action="Create"><i class="fas fa-plus"></i> Новый тип устройства</a></li>
                        </ul>
                    </li>
                }
            }

            <li class="menu-header mb-3 px-3 mt-4">
                <small class="text-uppercase text-muted">Дополнительно</small>
            </li>

            <li>
                <a asp-controller="Home" asp-action="Privacy">
                    <i class="fas fa-shield-alt"></i> Конфиденциальность
                </a>
            </li>

        </ul>

        <!-- Версия приложения -->
        <div class="sidebar-footer position-absolute bottom-0 w-100 p-3">
            <small class="text-muted">
                <i class="fas fa-code-branch me-1"></i> Версия 1.0.0
            </small>
        </div>
    </div>

    <!-- Оверлей для мобильного меню -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- Основной контент -->
    <div class="main-content" id="mainContent">
        <div class="content-wrapper">
            @if (!string.IsNullOrEmpty(controllerName))
            {
                <!-- Хлебные крошки -->
                <nav aria-label="breadcrumb" class="mb-4">
                    <ol class="breadcrumb bg-white p-3 rounded shadow-sm">
                        <li class="breadcrumb-item">
                            <a asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home"></i> Главная
                            </a>
                        </li>
                        @if (controllerName != "Home")
                        {
                            <li class="breadcrumb-item">
                                <a asp-controller="@controllerName" asp-action="Index">
                                    @displayController
                                </a>
                            </li>
                        }
                        @if (actionName != "Index")
                        {
                            <li class="breadcrumb-item active" aria-current="page">
                                @displayAction
                            </li>
                        }
                    </ol>
                </nav>
            }

            <!-- Уведомления -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i> @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- Заголовок страницы -->
            <div class="page-header mb-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="h3 mb-2">@ViewData["Title"]</h1>
                        @if (ViewData["Subtitle"] != null)
                        {
                            <p class="text-muted mb-0">@ViewData["Subtitle"]</p>
                        }
                    </div>
                    @if (ViewContext.RouteData.Values["action"]?.ToString() == "Index")
                    {
                        <div>
                            @if (ViewContext.RouteData.Values["controller"]?.ToString() == "ServiceOrders" &&
                                                    (User.IsInRole("Admin") || User.IsInRole("Employee") || User.IsInRole("Client")))
                            {
                                <a asp-action="Create" class="btn btn-primary">
                                    <i class="fas fa-plus me-1"></i> Создать заказ
                                </a>
                            }
                            else if (ViewContext.RouteData.Values["controller"]?.ToString() == "Customers" && User.IsInRole("Admin"))
                            {
                                <a asp-action="Create" class="btn btn-primary">
                                    <i class="fas fa-user-plus me-1"></i> Добавить клиента
                                </a>
                            }
                            else if (ViewContext.RouteData.Values["controller"]?.ToString() == "Technicians" && User.IsInRole("Admin"))
                            {
                                <a asp-action="Create" class="btn btn-primary">
                                    <i class="fas fa-user-cog me-1"></i> Добавить мастера
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Основной контент страницы -->
            <main>
                @RenderBody()
            </main>
        </div>

        <!-- Футер -->
        <footer class="footer">
            <div class="container">
                <div class="row">
                    <div class="col-md-6">
                        <p class="mb-0">
                            &copy; @DateTime.Now.Year - Компьютерный сервисный центр
                        </p>
                        <p class="text-muted small mb-0">
                            <i class="fas fa-tools me-1"></i> Ваш надежный партнер в ремонте техники
                        </p>
                    </div>
                    <div class="col-md-6 text-md-end">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <p class="text-muted small mb-0">
                                Вы вошли как: <strong>@User.Identity.Name</strong>
                                @{
                                    var user = await UserManager.GetUserAsync(User);
                                    if (user != null)
                                    {
                                        var roles = await UserManager.GetRolesAsync(user);
                                        if (roles.Contains("Admin"))
                                        {
                                            <span class="badge bg-danger ms-1">Администратор</span>
                                        }
                                        else if (roles.Contains("Employee"))
                                        {
                                            <span class="badge bg-warning text-dark ms-1">Сотрудник</span>
                                        }
                                        else if (roles.Contains("Client"))
                                        {
                                            <span class="badge bg-info ms-1">Клиент</span>
                                        }
                                    }
                                }
                            </p>
                        }
                        <p class="text-muted small mb-0">
                            <i class="fas fa-server me-1"></i> Серверное время: @DateTime.Now.ToString("dd.MM.yyyy HH:mm")
                        </p>
                    </div>
                </div>
            </div>
        </footer>
    </div>

    <!-- Скрипты -->
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- Bootstrap Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- DataTables -->
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>

    <!-- Select2 -->
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <!-- Toastr -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>

    <!-- Custom scripts -->
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Инициализация компонентов -->
    <script>
        // Инициализация DataTables
        $(document).ready(function() {
            $('.data-table').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.4/i18n/ru.json'
                },
                responsive: true,
                pageLength: 25
            });

            // Инициализация Select2
            $('.select2').select2({
                theme: 'bootstrap-5',
                width: '100%'
            });

            // Toastr уведомления
            toastr.options = {
                "closeButton": true,
                "progressBar": true,
                "positionClass": "toast-top-right",
                "timeOut": "5000"
            };

            @if (TempData["SuccessMessage"] != null)
            {
                    <text>toastr.success('@TempData["SuccessMessage"]', 'Успешно');</text>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                    <text>toastr.error('@TempData["ErrorMessage"]', 'Ошибка');</text>
            }
        });

        // Управление боковым меню
        document.addEventListener('DOMContentLoaded', function() {
            const sidebar = document.getElementById('sidebar');
            const sidebarToggle = document.getElementById('sidebarToggle');
            const sidebarOverlay = document.getElementById('sidebarOverlay');
            const mainContent = document.getElementById('mainContent');
            const themeToggle = document.getElementById('themeToggle');
            const submenuToggles = document.querySelectorAll('.has-submenu');

            // Переключение бокового меню
            sidebarToggle.addEventListener('click', function() {
                sidebar.classList.toggle('collapsed');
                mainContent.classList.toggle('expanded');

                if (window.innerWidth <= 992) {
                    sidebarOverlay.classList.toggle('show');
                }
            });

            // Закрытие меню при клике на оверлей (мобильные устройства)
            sidebarOverlay.addEventListener('click', function() {
                sidebar.classList.add('collapsed');
                sidebarOverlay.classList.remove('show');
                mainContent.classList.remove('expanded');
            });

            // Переключение подменю
            submenuToggles.forEach(toggle => {
                toggle.addEventListener('click', function(e) {
                    e.preventDefault();
                    const submenu = this.nextElementSibling;

                    // Закрываем все остальные подменю
                    document.querySelectorAll('.sidebar-submenu.show').forEach(openSubmenu => {
                        if (openSubmenu !== submenu) {
                            openSubmenu.classList.remove('show');
                        }
                    });

                    // Переключаем текущее подменю
                    submenu.classList.toggle('show');

                    // Поворачиваем иконку
                    const icon = this.querySelector('.fa-chevron-right');
                    if (submenu.classList.contains('show')) {
                        icon.style.transform = 'rotate(90deg)';
                    } else {
                        icon.style.transform = 'rotate(0deg)';
                    }
                });
            });

            // Переключение темы
            themeToggle.addEventListener('click', function() {
                const html = document.documentElement;
                const currentTheme = html.getAttribute('data-bs-theme');
                const newTheme = currentTheme === 'dark' ? 'light' : 'dark';

                html.setAttribute('data-bs-theme', newTheme);

                // Сохраняем в localStorage
                localStorage.setItem('theme', newTheme);

                // Меняем иконку
                const icon = this.querySelector('i');
                if (newTheme === 'dark') {
                    icon.className = 'fas fa-sun';
                    this.title = 'Переключить на светлую тему';
                } else {
                    icon.className = 'fas fa-moon';
                    this.title = 'Переключить на темную тему';
                }
            });

            // Восстанавливаем тему из localStorage
            const savedTheme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-bs-theme', savedTheme);

            // Устанавливаем правильную иконку
            if (savedTheme === 'dark') {
                themeToggle.querySelector('i').className = 'fas fa-sun';
                themeToggle.title = 'Переключить на светлую тему';
            } else {
                themeToggle.querySelector('i').className = 'fas fa-moon';
                themeToggle.title = 'Переключить на темную тему';
            }

            // Автоматическое скрытие уведомлений
            setTimeout(function() {
                $('.alert').alert('close');
            }, 5000);

            // Подсветка активного пункта меню
            const currentController = '@ViewContext.RouteData.Values["controller"]';
            const currentAction = '@ViewContext.RouteData.Values["action"]';

            // Устанавливаем активный пункт в сайдбаре
            document.querySelectorAll('.sidebar-menu a').forEach(link => {
                const href = link.getAttribute('href');
                if (href && href.includes(currentController) && href.includes(currentAction)) {
                    link.classList.add('active');

                    // Раскрываем родительское меню если есть
                    const parentMenu = link.closest('.sidebar-submenu');
                    if (parentMenu) {
                        parentMenu.classList.add('show');
                        const toggle = parentMenu.previousElementSibling;
                        if (toggle) {
                            toggle.querySelector('.fa-chevron-right').style.transform = 'rotate(90deg)';
                        }
                    }
                }
            });
        });

        // Функция подтверждения действий
        function confirmAction(message, callback) {
            if (confirm(message)) {
                callback();
            }
        }

        // Функция для показа загрузки
        function showLoading() {
            const loader = document.createElement('div');
            loader.className = 'loading-overlay';
            loader.innerHTML = `
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Загрузка...</span>
                </div>
            `;
            document.body.appendChild(loader);
        }

        // Функция для скрытия загрузки
        function hideLoading() {
            const loader = document.querySelector('.loading-overlay');
            if (loader) {
                loader.remove();
            }
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
