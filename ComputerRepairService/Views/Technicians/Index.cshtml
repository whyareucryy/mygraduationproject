@model IEnumerable<ComputerRepairService.Models.Entities.Technician>

@{
    ViewData["Title"] = "Мастера";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🛠️ Мастера</h2>
    <div>
        <a asp-action="Workload" class="btn btn-info me-2">
            <i class="fas fa-chart-bar"></i> Нагрузка
        </a>
        <a asp-action="Create" class="btn btn-success">
            <i class="fas fa-plus"></i> Добавить мастера
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Мастер</th>
                            <th>Специализация</th>
                            <th>Email</th>
                            <th>Телефон</th>
                            <th>Ставка (час)</th>
                            <th>Дата найма</th>
                            <th>Статус</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var technician in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@technician.FirstName @technician.LastName</strong>
                                </td>
                                <td>@technician.Specialization</td>
                                <td>@technician.Email</td>
                                <td>@technician.Phone</td>
                                <td>
                                    @if (technician.HourlyRate.HasValue)
                                    {
                                        <span class="badge bg-primary">@technician.HourlyRate.Value.ToString("C")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>@technician.HireDate.ToString("dd.MM.yyyy")</td>
                                <td>
                                    @if (technician.IsActive)
                                    {
                                        <span class="badge bg-success">Активен</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Неактивен</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@technician.TechnicianId" class="btn btn-info btn-sm" title="Детали">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@technician.TechnicianId" class="btn btn-warning btn-sm" title="Редактировать">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@technician.TechnicianId" class="btn btn-danger btn-sm" title="Удалить">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-4">
                <i class="fas fa-tools fa-3x text-muted mb-3"></i>
                <h4>Мастера не найдены</h4>
                <p class="text-muted">Начните с добавления первого мастера.</p>
                <a asp-action="Create" class="btn btn-success">
                    <i class="fas fa-plus"></i> Добавить мастера
                </a>
            </div>
        }
    </div>
</div>