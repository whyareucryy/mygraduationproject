@model ComputerRepairService.Models.Entities.Technician

@{
    ViewData["Title"] = "Удалить мастера";
}

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-danger text-white">
                <h4 class="card-title">Удаление мастера</h4>
            </div>
            <div class="card-body">
                <h5>Вы уверены, что хотите удалить этого мастера?</h5>
                <p class="text-muted">Это действие скроет мастера из списка, но сохранит историю его работы.</p>

                <div class="alert alert-warning">
                    <strong>Внимание:</strong> Это действие нельзя отменить.
                </div>

                <dl class="row">
                    <dt class="col-sm-4">Мастер:</dt>
                    <dd class="col-sm-8">@Model.FirstName @Model.LastName</dd>

                    <dt class="col-sm-4">Специализация:</dt>
                    <dd class="col-sm-8">@Model.Specialization</dd>

                    <dt class="col-sm-4">Email:</dt>
                    <dd class="col-sm-8">@Model.Email</dd>

                    <dt class="col-sm-4">Телефон:</dt>
                    <dd class="col-sm-8">@Model.Phone</dd>

                    <dt class="col-sm-4">Часовая ставка:</dt>
                    <dd class="col-sm-8">
                        @if (Model.HourlyRate.HasValue)
                        {
                            @Model.HourlyRate.Value.ToString("C")
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Дата найма:</dt>
                    <dd class="col-sm-8">@Model.HireDate.ToString("dd.MM.yyyy")</dd>
                </dl>

                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="TechnicianId" />
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash"></i> Удалить
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Отмена
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>