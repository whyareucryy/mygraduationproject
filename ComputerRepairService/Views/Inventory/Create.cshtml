@model ComputerRepairService.Models.Entities.Inventory

@{
    ViewData["Title"] = "Добавить позицию склада";
}

<div class="container mt-4">
    <h2 class="mb-4"><i class="fas fa-plus-circle"></i> Добавить позицию склада</h2>

    <div class="row">
        <div class="col-lg-8">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">Основная информация</div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="PartName" class="form-label"></label>
                            <input asp-for="PartName" class="form-control" placeholder="Например: SSD Kingston 1TB" />
                            <span asp-validation-for="PartName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CategoryId" class="form-label">Категория</label>
                            <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId">
                                <option value="">Выберите категорию</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Описание запчасти"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SupplierInfo" class="form-label"></label>
                            <input asp-for="SupplierInfo" class="form-control" placeholder="Поставщик / контакт" />
                            <span asp-validation-for="SupplierInfo" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-header bg-info text-white">Остатки и цена</div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label asp-for="QuantityInStock" class="form-label"></label>
                                <input asp-for="QuantityInStock" class="form-control" min="0" />
                                <span asp-validation-for="QuantityInStock" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="ReorderLevel" class="form-label"></label>
                                <input asp-for="ReorderLevel" class="form-control" min="0" />
                                <span asp-validation-for="ReorderLevel" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="UnitPrice" class="form-label"></label>
                                <div class="input-group">
                                    <input asp-for="UnitPrice" class="form-control" min="0" step="0.01" />
                                    <span class="input-group-text">₽</span>
                                </div>
                                <span asp-validation-for="UnitPrice" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn btn-success">
                    <i class="fas fa-save"></i> Сохранить
                </button>
                <a asp-action="Index" class="btn btn-secondary ms-2">
                    <i class="fas fa-times"></i> Отмена
                </a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
